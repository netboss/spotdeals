<?php

declare(strict_types=1);

use Drupal\Core\Cache\CacheBackendInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\node\NodeInterface;
use Drupal\views\ViewExecutable;

/**
 * Implements hook_form_views_exposed_form_alter().
 */
function spotdeals_search_smart_location_form_views_exposed_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  if (!isset($form['search_deals']) && !isset($form['search_api_fulltext'])) {
    return;
  }

  $form['#attached']['library'][] = 'spotdeals_search_smart_location/near_me';

  $form['origin_lat'] = [
    '#type' => 'hidden',
    '#value' => '',
  ];

  $form['origin_lon'] = [
    '#type' => 'hidden',
    '#value' => '',
  ];

  $form['search_origin_mode'] = [
    '#type' => 'hidden',
    '#value' => '',
  ];

  $form['search_clean'] = [
    '#type' => 'hidden',
    '#value' => '',
  ];

  $request = \Drupal::request();

  $is_reset_request = FALSE;
  foreach (['reset', 'op'] as $key) {
    $value = $request->query->get($key);
    if (is_string($value) && stripos($value, 'reset') !== FALSE) {
      $is_reset_request = TRUE;
      break;
    }
  }

  if ($is_reset_request) {
    if (isset($form['search_deals'])) {
      $form['search_deals']['#default_value'] = '';
      $form['search_deals']['#attributes']['value'] = '';
    }

    if (isset($form['search_api_fulltext'])) {
      $form['search_api_fulltext']['#default_value'] = '';
      $form['search_api_fulltext']['#attributes']['value'] = '';
    }

    $form['origin_lat']['#value'] = '';
    $form['origin_lon']['#value'] = '';
    $form['search_origin_mode']['#value'] = '';
    $form['search_clean']['#value'] = '';
  }

  $raw = $request->query->get('search_raw');

  if (!is_string($raw) || trim($raw) === '') {
    $raw = $request->attributes->get('spotdeals_search_smart_location.raw_query');
  }

  if (!is_string($raw) || trim($raw) === '') {
    $raw = $request->query->get('search_deals');
  }

  if (!is_string($raw) || trim($raw) === '') {
    $raw = $request->query->get('search_api_fulltext');
  }

  if (!$is_reset_request && is_string($raw) && trim($raw) !== '') {
    if (isset($form['search_deals'])) {
      $form['search_deals']['#default_value'] = $raw;
      $form['search_deals']['#attributes']['value'] = $raw;
    }

    if (isset($form['search_api_fulltext'])) {
      $form['search_api_fulltext']['#default_value'] = $raw;
      $form['search_api_fulltext']['#attributes']['value'] = $raw;
    }

    $form['search_raw'] = [
      '#type' => 'hidden',
      '#value' => $raw,
    ];
  }
  else {
    $form['search_raw'] = [
      '#type' => 'hidden',
      '#value' => '',
    ];
  }

  if (isset($form['postal_code_exact'])) {
    $form['postal_code_exact']['#type'] = 'hidden';
    $form['postal_code_exact']['#title_display'] = 'invisible';
  }

  if (isset($form['locality_exact'])) {
    $form['locality_exact']['#type'] = 'hidden';
    $form['locality_exact']['#title_display'] = 'invisible';
  }
}

/**
 * Implements hook_views_pre_view().
 */
function spotdeals_search_smart_location_views_pre_view(ViewExecutable $view, string $display_id, array &$args): void {
  if ($view->id() !== 'deals_search_solr' || $display_id !== 'page_1') {
    return;
  }

  $input = $view->getExposedInput();
  $request = \Drupal::request();

  $search_param = NULL;
  if (array_key_exists('search_deals', $input) || $request->query->has('search_deals')) {
    $search_param = 'search_deals';
  }
  elseif (array_key_exists('search_api_fulltext', $input) || $request->query->has('search_api_fulltext')) {
    $search_param = 'search_api_fulltext';
  }

  if ($search_param === NULL) {
    return;
  }

  $raw = $request->query->get('search_raw');
  if (!is_string($raw) || trim($raw) === '') {
    $raw = (string) ($input[$search_param] ?? $request->query->get($search_param, ''));
  }
  $raw = trim($raw);

  if ($raw === '') {
    return;
  }

  $request->attributes->set('spotdeals_search_smart_location.raw_query', $raw);

  unset($input['postal_code_exact'], $input['locality_exact']);

  $parsed = _spotdeals_search_smart_location_parse($raw);
  $clean = trim((string) $request->query->get('search_clean', ''));

  $origin_mode = (string) $request->query->get('search_origin_mode', '');
  $origin_lat = $request->query->get('origin_lat');
  $origin_lon = $request->query->get('origin_lon');

  $is_browser_near_me = $origin_mode === 'browser'
    && is_numeric($origin_lat)
    && is_numeric($origin_lon)
    && preg_match('/\bnear\s+me\b/i', $raw);

  if ($is_browser_near_me) {
    $nearest_city = _spotdeals_search_smart_location_nearest_city_from_coords(
      (float) $origin_lat,
      (float) $origin_lon
    );

    $keywords = $clean !== '' ? $clean : trim((string) ($parsed['keywords'] ?? ''));

    $input['search_raw'] = $raw;
    $input[$search_param] = $keywords;

    if (array_key_exists('search_deals', $input)) {
      $input['search_deals'] = $keywords;
    }

    if (array_key_exists('search_api_fulltext', $input)) {
      $input['search_api_fulltext'] = $keywords;
    }

    if (is_string($nearest_city) && $nearest_city !== '') {
      $input['locality_exact'] = $nearest_city;
      $request->attributes->set('spotdeals_search_smart_location.city', $nearest_city);

      \Drupal::logger('spotdeals_search_smart_location')->notice(
        'SMART LOCATION browser near me applied: view="@view" display="@display" raw="@raw" keywords="@keywords" nearest_city="@city" origin_lat="@lat" origin_lon="@lon"',
        [
          '@view' => $view->id(),
          '@display' => $display_id,
          '@raw' => $raw,
          '@keywords' => $keywords,
          '@city' => $nearest_city,
          '@lat' => (string) $origin_lat,
          '@lon' => (string) $origin_lon,
        ]
      );
    }

    $view->setExposedInput($input);
    return;
  }

  if (empty($parsed['zip']) && empty($parsed['city'])) {
    \Drupal::logger('spotdeals_search_smart_location')->notice(
      'SMART LOCATION no location found: view="@view" display="@display" raw="@raw"',
      [
        '@view' => $view->id(),
        '@display' => $display_id,
        '@raw' => $raw,
      ]
    );
    return;
  }

  $input['search_raw'] = $raw;
  $input[$search_param] = $parsed['keywords'];

  if (array_key_exists('search_deals', $input)) {
    $input['search_deals'] = $parsed['keywords'];
  }

  if (array_key_exists('search_api_fulltext', $input)) {
    $input['search_api_fulltext'] = $parsed['keywords'];
  }

  if (!empty($parsed['zip'])) {
    $input['postal_code_exact'] = $parsed['zip'];
  }

  if (!empty($parsed['city'])) {
    $exact_city = _spotdeals_search_smart_location_city_to_exact_locality($parsed['city']);
    if ($exact_city !== NULL) {
      $input['locality_exact'] = $exact_city;
      $request->attributes->set('spotdeals_search_smart_location.city', $exact_city);
    }
  }

  $origin = _spotdeals_search_smart_location_resolve_origin_from_venues($parsed);
  if ($origin) {
    $request->attributes->set('spotdeals_search_smart_location.origin', $origin);
  }

  $view->setExposedInput($input);

  \Drupal::logger('spotdeals_search_smart_location')->notice(
    'SMART LOCATION applied: view="@view" display="@display" raw="@raw" keywords="@keywords" zip="@zip" city="@city" exact_city="@exact_city" origin_lat="@origin_lat" origin_lon="@origin_lon" search_param="@search_param"',
    [
      '@view' => $view->id(),
      '@display' => $display_id,
      '@raw' => $raw,
      '@keywords' => $parsed['keywords'] ?? '',
      '@zip' => $input['postal_code_exact'] ?? '',
      '@city' => $parsed['city'] ?? '',
      '@exact_city' => $input['locality_exact'] ?? '',
      '@origin_lat' => $origin['lat'] ?? '',
      '@origin_lon' => $origin['lon'] ?? '',
      '@search_param' => $search_param,
    ]
  );
}

/**
 * Parse one-box input into keywords + zip + city.
 */
function _spotdeals_search_smart_location_parse(string $input): array {
  $working = trim($input);

  $zip = NULL;
  $city = NULL;

  if (preg_match('/\b(\d{5})\b/', $working, $matches)) {
    $zip = $matches[1];
    $working = preg_replace('/\b' . preg_quote($zip, '/') . '\b/i', ' ', $working, 1) ?? $working;
  }

  $known_cities = _spotdeals_search_smart_location_known_cities();
  $normalized_query = _spotdeals_search_smart_location_normalize($working);

  uksort($known_cities, static fn(string $a, string $b): int => mb_strlen($b) <=> mb_strlen($a));

  foreach ($known_cities as $canonical_city => $aliases) {
    foreach ($aliases as $alias) {
      $normalized_alias = _spotdeals_search_smart_location_normalize($alias);
      if ($normalized_alias === '') {
        continue;
      }

      $pattern = '/(^|\s)' . preg_quote($normalized_alias, '/') . '($|\s)/iu';
      if (preg_match($pattern, ' ' . $normalized_query . ' ')) {
        $city = $canonical_city;
        $working = preg_replace('/\b' . preg_quote($alias, '/') . '\b/iu', ' ', $working) ?? $working;
        break 2;
      }
    }
  }

  $keywords = trim(preg_replace('/\s+/', ' ', $working) ?? '');

  return [
    'keywords' => $keywords,
    'zip' => $zip,
    'city' => $city,
  ];
}

/**
 * Returns searchable city aliases derived from Venue node data.
 */
function _spotdeals_search_smart_location_known_cities(): array {
  $cid = 'spotdeals_search_smart_location:known_cities_from_venues';

  $cache = \Drupal::cache()->get($cid);
  if ($cache && is_array($cache->data)) {
    return $cache->data;
  }

  $cities = [];
  $storage = \Drupal::entityTypeManager()->getStorage('node');

  $nids = \Drupal::entityQuery('node')
    ->accessCheck(FALSE)
    ->condition('type', 'venue')
    ->condition('status', 1)
    ->exists('field_address.locality')
    ->execute();

  if (!empty($nids)) {
    $venues = $storage->loadMultiple($nids);

    foreach ($venues as $venue) {
      if (!$venue instanceof NodeInterface) {
        continue;
      }

      if (!$venue->hasField('field_address') || $venue->get('field_address')->isEmpty()) {
        continue;
      }

      $address = $venue->get('field_address')->first();
      $locality = trim((string) ($address->getLocality() ?? ''));
      if ($locality === '') {
        continue;
      }

      $cities[$locality] = $cities[$locality] ?? [$locality];

      $acronym = _spotdeals_search_smart_location_acronym($locality);
      if ($acronym !== NULL) {
        $cities[$locality][] = $acronym;
      }

      $cities[$locality] = array_values(array_unique(array_filter($cities[$locality])));
    }
  }

  ksort($cities, SORT_NATURAL | SORT_FLAG_CASE);
  \Drupal::cache()->set($cid, $cities, CacheBackendInterface::CACHE_PERMANENT);

  return $cities;
}

/**
 * Builds a simple acronym for multi-word city labels, e.g. NSB.
 */
function _spotdeals_search_smart_location_acronym(string $label): ?string {
  $parts = preg_split('/\s+/', trim($label)) ?: [];
  if (count($parts) < 2) {
    return NULL;
  }

  $letters = '';
  foreach ($parts as $part) {
    $part = trim($part);
    if ($part === '') {
      continue;
    }
    $letters .= mb_strtoupper(mb_substr($part, 0, 1));
  }

  return $letters !== '' ? $letters : NULL;
}

/**
 * Maps parsed city to exact locality if it exists in venue data.
 */
function _spotdeals_search_smart_location_city_to_exact_locality(string $city): ?string {
  $cities = _spotdeals_search_smart_location_known_cities();
  return array_key_exists($city, $cities) ? $city : NULL;
}

/**
 * Resolves parsed city/ZIP to approximate coordinates from Venue nodes.
 */
function _spotdeals_search_smart_location_resolve_origin_from_venues(array $parsed): ?array {
  $lookup = _spotdeals_search_smart_location_build_venue_origin_lookup();

  if (!empty($parsed['zip']) && isset($lookup['zips'][$parsed['zip']])) {
    return $lookup['zips'][$parsed['zip']];
  }

  if (!empty($parsed['city']) && isset($lookup['cities'][$parsed['city']])) {
    return $lookup['cities'][$parsed['city']];
  }

  return NULL;
}

/**
 * Builds city/ZIP coordinate lookup from Venue nodes.
 */
function _spotdeals_search_smart_location_build_venue_origin_lookup(): array {
  $cid = 'spotdeals_search_smart_location:venue_origin_lookup';

  $cache = \Drupal::cache()->get($cid);
  if ($cache && is_array($cache->data)) {
    return $cache->data;
  }

  $lookup = [
    'cities' => [],
    'zips' => [],
  ];

  $city_sums = [];
  $zip_sums = [];

  $storage = \Drupal::entityTypeManager()->getStorage('node');

  $nids = \Drupal::entityQuery('node')
    ->accessCheck(FALSE)
    ->condition('type', 'venue')
    ->condition('status', 1)
    ->exists('field_address.locality')
    ->exists('field_coordinates')
    ->execute();

  if (empty($nids)) {
    \Drupal::cache()->set($cid, $lookup, CacheBackendInterface::CACHE_PERMANENT);
    return $lookup;
  }

  $venues = $storage->loadMultiple($nids);

  foreach ($venues as $venue) {
    if (!$venue instanceof NodeInterface) {
      continue;
    }

    $coords = _spotdeals_search_smart_location_node_coords($venue);
    if ($coords === NULL) {
      continue;
    }

    [$lat, $lon] = $coords;

    if (!$venue->hasField('field_address') || $venue->get('field_address')->isEmpty()) {
      continue;
    }

    $address = $venue->get('field_address')->first();
    $city = trim((string) ($address->getLocality() ?? ''));
    $zip = trim((string) ($address->getPostalCode() ?? ''));

    if ($city !== '') {
      if (!isset($city_sums[$city])) {
        $city_sums[$city] = [
          'lat_sum' => 0.0,
          'lon_sum' => 0.0,
          'count' => 0,
        ];
      }

      $city_sums[$city]['lat_sum'] += $lat;
      $city_sums[$city]['lon_sum'] += $lon;
      $city_sums[$city]['count']++;
    }

    if ($zip !== '') {
      if (!isset($zip_sums[$zip])) {
        $zip_sums[$zip] = [
          'lat_sum' => 0.0,
          'lon_sum' => 0.0,
          'count' => 0,
        ];
      }

      $zip_sums[$zip]['lat_sum'] += $lat;
      $zip_sums[$zip]['lon_sum'] += $lon;
      $zip_sums[$zip]['count']++;
    }
  }

  foreach ($city_sums as $city => $data) {
    if ($data['count'] > 0) {
      $lookup['cities'][$city] = [
        'lat' => round($data['lat_sum'] / $data['count'], 6),
        'lon' => round($data['lon_sum'] / $data['count'], 6),
      ];
    }
  }

  foreach ($zip_sums as $zip => $data) {
    if ($data['count'] > 0) {
      $lookup['zips'][$zip] = [
        'lat' => round($data['lat_sum'] / $data['count'], 6),
        'lon' => round($data['lon_sum'] / $data['count'], 6),
      ];
    }
  }

  \Drupal::cache()->set($cid, $lookup, CacheBackendInterface::CACHE_PERMANENT);
  return $lookup;
}

/**
 * Returns the nearest known city centroid for browser coords.
 */
function _spotdeals_search_smart_location_nearest_city_from_coords(float $origin_lat, float $origin_lon): ?string {
  $lookup = _spotdeals_search_smart_location_build_venue_origin_lookup();

  if (empty($lookup['cities']) || !is_array($lookup['cities'])) {
    return NULL;
  }

  $nearest_city = NULL;
  $nearest_distance = NULL;

  foreach ($lookup['cities'] as $city => $coords) {
    if (
      !is_array($coords) ||
      !isset($coords['lat'], $coords['lon']) ||
      !is_numeric($coords['lat']) ||
      !is_numeric($coords['lon'])
    ) {
      continue;
    }

    $distance = _spotdeals_search_smart_location_haversine_km(
      $origin_lat,
      $origin_lon,
      (float) $coords['lat'],
      (float) $coords['lon']
    );

    if ($nearest_distance === NULL || $distance < $nearest_distance) {
      $nearest_distance = $distance;
      $nearest_city = $city;
    }
  }

  return $nearest_city;
}

/**
 * Extracts [lat, lon] from a Venue node.
 *
 * Prefers field_coordinates POINT(lon lat), falls back to field_latitude /
 * field_longitude if present.
 *
 * @return array<int, float>|null
 *   Returns [lat, lon] or NULL.
 */
function _spotdeals_search_smart_location_node_coords(NodeInterface $node): ?array {
  if ($node->hasField('field_coordinates') && !$node->get('field_coordinates')->isEmpty()) {
    $raw = trim((string) $node->get('field_coordinates')->value);

    if (preg_match('/POINT\s*\(\s*(-?[0-9.]+)\s+(-?[0-9.]+)\s*\)/i', $raw, $matches)) {
      $lon = (float) $matches[1];
      $lat = (float) $matches[2];
      return [$lat, $lon];
    }
  }

  if (
    $node->hasField('field_latitude') &&
    !$node->get('field_latitude')->isEmpty() &&
    $node->hasField('field_longitude') &&
    !$node->get('field_longitude')->isEmpty()
  ) {
    $lat = $node->get('field_latitude')->value;
    $lon = $node->get('field_longitude')->value;

    if (is_numeric($lat) && is_numeric($lon)) {
      return [(float) $lat, (float) $lon];
    }
  }

  return NULL;
}

/**
 * Normalizes a search string for loose matching.
 */
function _spotdeals_search_smart_location_normalize(string $value): string {
  $value = mb_strtolower($value);
  $value = preg_replace('/[^\p{L}\p{N}\s]+/u', ' ', $value) ?? $value;
  $value = preg_replace('/\s+/', ' ', $value) ?? $value;
  return trim($value);
}

/**
 * Returns great-circle distance in kilometers.
 */
function _spotdeals_search_smart_location_haversine_km(float $lat1, float $lon1, float $lat2, float $lon2): float {
  $earth_radius_km = 6371.0;

  $lat1_rad = deg2rad($lat1);
  $lon1_rad = deg2rad($lon1);
  $lat2_rad = deg2rad($lat2);
  $lon2_rad = deg2rad($lon2);

  $dlat = $lat2_rad - $lat1_rad;
  $dlon = $lon2_rad - $lon1_rad;

  $a = sin($dlat / 2) ** 2
    + cos($lat1_rad) * cos($lat2_rad) * sin($dlon / 2) ** 2;

  $c = 2 * atan2(sqrt($a), sqrt(1 - $a));

  return $earth_radius_km * $c;
}

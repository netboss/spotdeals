<?php

declare(strict_types=1);

use Drupal\Core\Cache\CacheBackendInterface;
use Drupal\Core\Database\Database;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Url;
use Drupal\node\NodeInterface;
use Drupal\views\ViewExecutable;


/**
 * Implements hook_theme().
 */
function spotdeals_search_smart_location_theme(): array {
  return [
    'spotdeals_search_smart_location_recommendation_note' => [
      'variables' => [
        'keyword' => '',
      ],
      'template' => 'spotdeals-search-smart-location-recommendation-note',
    ],
  ];
}

/**
 * Implements hook_form_views_exposed_form_alter().
 */
function spotdeals_search_smart_location_form_views_exposed_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  if (!isset($form['search_deals']) && !isset($form['search_api_fulltext'])) {
    return;
  }

  $form['#attached']['library'][] = 'spotdeals_search_smart_location/near_me';

  $form['origin_lat'] = [
    '#type' => 'hidden',
    '#value' => '',
  ];

  $form['origin_lon'] = [
    '#type' => 'hidden',
    '#value' => '',
  ];

  $form['search_origin_mode'] = [
    '#type' => 'hidden',
    '#value' => '',
  ];

  $form['search_clean'] = [
    '#type' => 'hidden',
    '#value' => '',
  ];

  $request = \Drupal::request();

  $form['recommendation_action'] = [
    '#type' => 'hidden',
    '#value' => (string) $request->query->get('recommendation_action', ''),
  ];

  $form['#validate'][] = 'spotdeals_search_smart_location_recommendation_validate';
  $form['#submit'][] = 'spotdeals_search_smart_location_exposed_form_submit';

  $is_reset_request = FALSE;
  foreach (['reset', 'op'] as $key) {
    $value = $request->query->get($key);
    if (is_string($value) && stripos($value, 'reset') !== FALSE) {
      $is_reset_request = TRUE;
      break;
    }
  }

  $recommendation_mode = !$is_reset_request
    && _spotdeals_search_smart_location_is_recommendation_mode($request->query->all());
  $recommendation_cuisines_value = $is_reset_request
    ? ''
    : (string) $request->query->get('recommendation_cuisines', '');

  $form['#attributes']['data-recommendation-active'] = _spotdeals_search_smart_location_has_current_recommendation() ? '1' : '0';

  $form['help_me_choose'] = [
    '#type' => 'checkbox',
    '#title' => t('Not sure what to eat? We’ll pick for you!'),
    '#default_value' => $recommendation_mode ? 1 : 0,
    '#weight' => 100,
  ];

  $form['recommendation_cuisines'] = [
    '#type' => 'textfield',
    '#title' => t('Cuisine preferences'),
    '#default_value' => $recommendation_cuisines_value,
    '#description' => t('Optional. Enter up to 5 cuisine ideas separated by spaces, or leave this empty and we’ll surprise you.'),
    '#size' => 60,
    '#maxlength' => 255,
    '#weight' => 101,
    '#states' => [
      'visible' => [
        ':input[name="help_me_choose"]' => ['checked' => TRUE],
      ],
    ],
  ];

  // Move form action buttons below the recommendation controls so the
  // exposed-form flow feels more natural.
  if (isset($form['actions']) && is_array($form['actions'])) {
    $form['actions']['#weight'] = 110;

    if (isset($form['actions']['submit'])) {
      $form['actions']['submit']['#weight'] = 0;
      $form['actions']['submit']['#value'] = _spotdeals_search_smart_location_has_current_recommendation() ? t('Try again') : t('Find deals');
    }

    if (isset($form['actions']['reset'])) {
      $form['actions']['reset']['#weight'] = 1;
    }
  }

  if (isset($form['submit'])) {
    $form['submit']['#weight'] = 110;
    $form['submit']['#value'] = _spotdeals_search_smart_location_has_current_recommendation() ? t('Try again') : t('Find deals');
  }

  if (isset($form['reset'])) {
    $form['reset']['#weight'] = 111;
  }

  if ($is_reset_request) {
    $form['help_me_choose']['#default_value'] = 0;
    $form['recommendation_cuisines']['#default_value'] = '';
    if (isset($form['search_deals'])) {
      $form['search_deals']['#default_value'] = '';
      $form['search_deals']['#attributes']['value'] = '';
    }

    if (isset($form['search_api_fulltext'])) {
      $form['search_api_fulltext']['#default_value'] = '';
      $form['search_api_fulltext']['#attributes']['value'] = '';
    }

    $form['origin_lat']['#value'] = '';
    $form['origin_lon']['#value'] = '';
    $form['search_origin_mode']['#value'] = '';
    $form['search_clean']['#value'] = '';
  }

  $raw = $request->query->get('search_raw');

  if (!is_string($raw) || trim($raw) === '') {
    $raw = $request->attributes->get('spotdeals_search_smart_location.raw_query');
  }

  if (!is_string($raw) || trim($raw) === '') {
    $raw = $request->query->get('search_deals');
  }

  if (!is_string($raw) || trim($raw) === '') {
    $raw = $request->query->get('search_api_fulltext');
  }

  if (!$is_reset_request && is_string($raw) && trim($raw) !== '') {
    if (isset($form['search_deals'])) {
      $form['search_deals']['#default_value'] = $raw;
      $form['search_deals']['#attributes']['value'] = $raw;
    }

    if (isset($form['search_api_fulltext'])) {
      $form['search_api_fulltext']['#default_value'] = $raw;
      $form['search_api_fulltext']['#attributes']['value'] = $raw;
    }

    $form['search_raw'] = [
      '#type' => 'hidden',
      '#value' => $raw,
    ];
  }
  else {
    $form['search_raw'] = [
      '#type' => 'hidden',
      '#value' => '',
    ];
  }

  if (isset($form['postal_code_exact'])) {
    $form['postal_code_exact']['#type'] = 'hidden';
    $form['postal_code_exact']['#title_display'] = 'invisible';
  }

  if (isset($form['locality_exact'])) {
    $form['locality_exact']['#type'] = 'hidden';
    $form['locality_exact']['#title_display'] = 'invisible';
  }
}

/**
 * Implements hook_views_pre_view().
 */
function spotdeals_search_smart_location_views_pre_view(ViewExecutable $view, string $display_id, array &$args): void {
  if ($view->id() !== 'deals_search_solr' || $display_id !== 'page_1') {
    return;
  }

  $input = $view->getExposedInput();
  $request = \Drupal::request();

  $search_param = NULL;
  if (array_key_exists('search_deals', $input) || $request->query->has('search_deals')) {
    $search_param = 'search_deals';
  }
  elseif (array_key_exists('search_api_fulltext', $input) || $request->query->has('search_api_fulltext')) {
    $search_param = 'search_api_fulltext';
  }

  if ($search_param === NULL) {
    return;
  }

  $raw = $request->query->get('search_raw');
  if (!is_string($raw) || trim($raw) === '') {
    $raw = (string) ($input[$search_param] ?? $request->query->get($search_param, ''));
  }
  $raw = trim($raw);

  $recommendation_mode = _spotdeals_search_smart_location_is_recommendation_mode($input + $request->query->all());
  if ($recommendation_mode) {
    \Drupal::service('page_cache_kill_switch')->trigger();
  }
  $recommendation_cuisines = _spotdeals_search_smart_location_parse_recommendation_cuisines(
    (string) ($input['recommendation_cuisines'] ?? $request->query->get('recommendation_cuisines', ''))
  );
  $recommendation_keywords = implode(' ', $recommendation_cuisines);

  $request->attributes->set('spotdeals_search_smart_location.recommendation_mode', $recommendation_mode);
  $request->attributes->set('spotdeals_search_smart_location.recommendation_cuisines', $recommendation_cuisines);
  $request->attributes->set('spotdeals_search_smart_location.recommended_deal_nids', []);

  $recommendation_action = strtolower(trim((string) ($input['recommendation_action'] ?? $request->query->get('recommendation_action', ''))));
  $request->attributes->set('spotdeals_search_smart_location.recommendation_action', $recommendation_action);

  if ($recommendation_action === 'reset') {
    _spotdeals_search_smart_location_reset_recommendation_session();
  }
  elseif ($recommendation_action === 'retry') {
    _spotdeals_search_smart_location_apply_recommendation_action_to_session($recommendation_action);
  }

  $excluded_venue_nids = _spotdeals_search_smart_location_get_recommendation_exclusions();
  $request->attributes->set('spotdeals_search_smart_location.excluded_venue_nids', $excluded_venue_nids);

  \Drupal::logger('spotdeals_search_smart_location')->notice(
    'SMART LOCATION recommendation request state: action="@action" excluded="@excluded" current="@current"',
    [
      '@action' => $recommendation_action,
      '@excluded' => json_encode($excluded_venue_nids, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE),
      '@current' => json_encode(\Drupal::request()->getSession()->get('spotdeals_search_smart_location.current_recommendation', []), JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE),
    ]
  );

  if ($raw === '' && !$recommendation_mode) {
    return;
  }

  $request->attributes->set('spotdeals_search_smart_location.raw_query', $raw);

  unset($input['postal_code_exact'], $input['locality_exact']);

  $parsed = _spotdeals_search_smart_location_parse($raw);
  $clean = _spotdeals_search_smart_location_normalize_keywords(
    trim((string) $request->query->get('search_clean', ''))
  );

  $recommendation_fallback_source = $clean !== ''
    ? $clean
    : trim((string) ($parsed['keywords'] ?? ''));
  $effective_recommendation_cuisines = !empty($recommendation_cuisines)
    ? $recommendation_cuisines
    : _spotdeals_search_smart_location_parse_recommendation_cuisines($recommendation_fallback_source);
  $effective_recommendation_keywords = implode(' ', $effective_recommendation_cuisines);

  $origin_mode = (string) $request->query->get('search_origin_mode', '');
  $origin_lat = $request->query->get('origin_lat');
  $origin_lon = $request->query->get('origin_lon');

  $has_browser_origin = $origin_mode === 'browser'
    && is_numeric($origin_lat)
    && is_numeric($origin_lon);

  $is_browser_near_me = $has_browser_origin
    && empty($parsed['zip'])
    && empty($parsed['city']);

  if ($is_browser_near_me) {
    $nearest_city = _spotdeals_search_smart_location_nearest_city_from_coords(
      (float) $origin_lat,
      (float) $origin_lon
    );

    $keywords = $recommendation_mode && $effective_recommendation_keywords !== ''
      ? $effective_recommendation_keywords
      : ($clean !== '' ? $clean : trim((string) ($parsed['keywords'] ?? '')));
    $keywords = _spotdeals_search_smart_location_normalize_keywords($keywords);
    $keywords = _spotdeals_search_smart_location_expand_keywords($keywords);

    unset($input['postal_code_exact'], $input['locality_exact']);

    $request->attributes->set('spotdeals_search_smart_location.origin', [
      'lat' => (float) $origin_lat,
      'lon' => (float) $origin_lon,
    ]);
    $request->attributes->set('spotdeals_search_smart_location.browser_near_me', TRUE);
    $request->attributes->set('spotdeals_search_smart_location.city', $nearest_city ?? '');
    $request->attributes->set('spotdeals_search_smart_location.zip', '');

    $ranked_nids = \Drupal::service('spotdeals_search_smart_location.near_me_ranker')
      ->rankDealNids((float) $origin_lat, (float) $origin_lon, $keywords);

    $request->attributes->set('spotdeals_search_smart_location.ranked_deal_nids', $ranked_nids);

    $recommended_nids = [];
    if ($recommendation_mode) {
      $recommended_nids = \Drupal::service('spotdeals_search_smart_location.recommendation_service')
        ->recommendDealNids(
          (float) $origin_lat,
          (float) $origin_lon,
          $effective_recommendation_cuisines,
          25.0,
          [],
          $excluded_venue_nids
        );
      $request->attributes->set('spotdeals_search_smart_location.recommended_deal_nids', $recommended_nids);
      $request->attributes->set(
        'spotdeals_search_smart_location.direct_recommendation_deal_nid',
        !empty($recommended_nids[0]) ? (int) $recommended_nids[0] : 0
      );
      _spotdeals_search_smart_location_store_current_recommendation($recommended_nids);

      \Drupal::logger('spotdeals_search_smart_location')->notice(
        'SMART LOCATION recommendation service result from browser origin: excluded="@excluded" recommended="@recommended"',
        [
          '@excluded' => json_encode($excluded_venue_nids, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE),
          '@recommended' => json_encode($recommended_nids, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE),
        ]
      );
    }

    $request->attributes->set('spotdeals_search_smart_location.fallback_broader_search', FALSE);
    $request->attributes->set('spotdeals_search_smart_location.fallback_broader_search_pending', FALSE);
    $request->attributes->set('spotdeals_search_smart_location.browser_near_me_context', [
      'keywords' => $keywords,
      'nearest_city' => $nearest_city ?? '',
      'origin_lat' => (float) $origin_lat,
      'origin_lon' => (float) $origin_lon,
      'search_param' => $search_param,
    ]);

    if (!$recommendation_mode && $keywords !== '' && empty($ranked_nids)) {
      $broader_ranked_nids = \Drupal::service('spotdeals_search_smart_location.near_me_ranker')
        ->rankDealNids((float) $origin_lat, (float) $origin_lon, $keywords, 1000.0);

      if (!empty($broader_ranked_nids)) {
        $request->attributes->set('spotdeals_search_smart_location.fallback_broader_search', TRUE);
        $request->attributes->set('spotdeals_search_smart_location.browser_near_me', FALSE);
        $request->attributes->set('spotdeals_search_smart_location.city', '');
        $request->attributes->set('spotdeals_search_smart_location.zip', '');
        $request->attributes->set('spotdeals_search_smart_location.ranked_deal_nids', []);

        \Drupal::logger('spotdeals_search_smart_location')->notice(
          'SMART LOCATION broadened browser near-me keyword search before View execution: view="@view" display="@display" raw="@raw" keywords="@keywords" nearest_city="@city" origin_lat="@lat" origin_lon="@lon" local_ranked_count="0" broader_ranked_count="@broader"',
          [
            '@view' => $view->id(),
            '@display' => $display_id,
            '@raw' => $raw,
            '@keywords' => $keywords,
            '@city' => $nearest_city ?? '',
            '@lat' => (string) $origin_lat,
            '@lon' => (string) $origin_lon,
            '@broader' => (string) count($broader_ranked_nids),
          ]
        );
      }
    }

    $solr_keywords = $keywords;

    _spotdeals_search_smart_location_prepare_search_insight($raw, $solr_keywords, $recommendation_mode);

    $input['search_raw'] = $raw;
    $input[$search_param] = $solr_keywords;

    if (array_key_exists('search_deals', $input)) {
      $input['search_deals'] = $solr_keywords;
    }

    if (array_key_exists('search_api_fulltext', $input)) {
      $input['search_api_fulltext'] = $solr_keywords;
    }

    \Drupal::logger('spotdeals_search_smart_location')->notice(
      'SMART LOCATION default near-me applied from browser origin: view="@view" display="@display" raw="@raw" keywords="@keywords" solr_keywords="@solr_keywords" recommendation_mode="@recommendation_mode" recommended_count="@recommended" nearest_city="@city" origin_lat="@lat" origin_lon="@lon" ranked_count="@ranked" city_filter="off"',
      [
        '@view' => $view->id(),
        '@display' => $display_id,
        '@raw' => $raw,
        '@keywords' => $keywords,
        '@solr_keywords' => $solr_keywords,
        '@recommendation_mode' => $recommendation_mode ? '1' : '0',
        '@recommended' => (string) count($recommended_nids),
        '@city' => $nearest_city ?? '',
        '@lat' => (string) $origin_lat,
        '@lon' => (string) $origin_lon,
        '@ranked' => (string) count($ranked_nids),
      ]
    );

    $view->setExposedInput($input);
    return;
  }

  $request->attributes->set('spotdeals_search_smart_location.browser_near_me', FALSE);
  $request->attributes->set('spotdeals_search_smart_location.city', '');
  $request->attributes->set('spotdeals_search_smart_location.zip', '');

  if (empty($parsed['zip']) && empty($parsed['city'])) {
    \Drupal::logger('spotdeals_search_smart_location')->notice(
      'SMART LOCATION no explicit location found and no browser origin available: view="@view" display="@display" raw="@raw" recommendation_mode="@recommendation_mode"',
      [
        '@view' => $view->id(),
        '@display' => $display_id,
        '@raw' => $raw,
        '@recommendation_mode' => $recommendation_mode ? '1' : '0',
      ]
    );
    return;
  }

  if ($recommendation_mode && $effective_recommendation_keywords !== '') {
    $parsed['keywords'] = $effective_recommendation_keywords;
  }

  _spotdeals_search_smart_location_prepare_search_insight($raw, (string) ($parsed['keywords'] ?? ''), $recommendation_mode);

  $input['search_raw'] = $raw;
  $input[$search_param] = $parsed['keywords'];

  if (array_key_exists('search_deals', $input)) {
    $input['search_deals'] = $parsed['keywords'];
  }

  if (array_key_exists('search_api_fulltext', $input)) {
    $input['search_api_fulltext'] = $parsed['keywords'];
  }

  $exact_city = '';
  if (!empty($parsed['city'])) {
    $resolved = _spotdeals_search_smart_location_city_to_exact_locality($parsed['city']);
    if ($resolved !== NULL) {
      $exact_city = $resolved;
      $request->attributes->set('spotdeals_search_smart_location.city', $exact_city);
      $input['locality_exact'] = $exact_city;
      _spotdeals_search_smart_location_force_filter_value($view, 'locality_exact', $exact_city);
    }
  }

  if (!empty($parsed['zip'])) {
    $request->attributes->set('spotdeals_search_smart_location.zip', $parsed['zip']);
    $input['postal_code_exact'] = $parsed['zip'];
    _spotdeals_search_smart_location_force_filter_value($view, 'postal_code_exact', $parsed['zip']);
  }

  $origin = _spotdeals_search_smart_location_resolve_origin_from_venues($parsed);
  if ($origin) {
    $request->attributes->set('spotdeals_search_smart_location.origin', $origin);

    if ($recommendation_mode) {
      $recommended_nids = \Drupal::service('spotdeals_search_smart_location.recommendation_service')
        ->recommendDealNids(
          (float) $origin['lat'],
          (float) $origin['lon'],
          $effective_recommendation_cuisines,
          25.0,
          [],
          $excluded_venue_nids
        );
      $request->attributes->set('spotdeals_search_smart_location.recommended_deal_nids', $recommended_nids);
      $request->attributes->set(
        'spotdeals_search_smart_location.direct_recommendation_deal_nid',
        !empty($recommended_nids[0]) ? (int) $recommended_nids[0] : 0
      );
      _spotdeals_search_smart_location_store_current_recommendation($recommended_nids);

      \Drupal::logger('spotdeals_search_smart_location')->notice(
        'SMART LOCATION recommendation service result from resolved origin: excluded="@excluded" recommended="@recommended"',
        [
          '@excluded' => json_encode($excluded_venue_nids, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE),
          '@recommended' => json_encode($recommended_nids, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE),
        ]
      );
    }
  }

  $view->setExposedInput($input);

  \Drupal::logger('spotdeals_search_smart_location')->notice(
    'SMART LOCATION applied explicit location override: view="@view" display="@display" raw="@raw" keywords="@keywords" zip="@zip" city="@city" exact_city="@exact_city" origin_lat="@origin_lat" origin_lon="@origin_lon" search_param="@search_param"',
    [
      '@view' => $view->id(),
      '@display' => $display_id,
      '@raw' => $raw,
      '@keywords' => $parsed['keywords'] ?? '',
      '@zip' => $parsed['zip'] ?? '',
      '@city' => $parsed['city'] ?? '',
      '@exact_city' => $exact_city,
      '@origin_lat' => $origin['lat'] ?? '',
      '@origin_lon' => $origin['lon'] ?? '',
      '@search_param' => $search_param,
    ]
  );
}

/**
 * Implements hook_views_pre_render().
 */
function spotdeals_search_smart_location_views_pre_render(ViewExecutable $view): void {
  if ($view->id() !== 'deals_search_solr' || $view->current_display !== 'page_1') {
    return;
  }

  $request = \Drupal::request();
  $recommendation_mode = (bool) $request->attributes->get('spotdeals_search_smart_location.recommendation_mode', FALSE);

  if (!$recommendation_mode) {
    _spotdeals_search_smart_location_apply_ranked_order($view);
  }

  _spotdeals_search_smart_location_commit_search_insight($view);
}

/**
 * Implements hook_preprocess_views_view().
 */
function spotdeals_search_smart_location_preprocess_views_view(array &$variables): void {
  if (empty($variables['view']) || !$variables['view'] instanceof ViewExecutable) {
    return;
  }

  $view = $variables['view'];
  if ($view->id() !== 'deals_search_solr' || $view->current_display !== 'page_1') {
    return;
  }

  $request = \Drupal::request();
  $recommendation_mode = (bool) $request->attributes->get('spotdeals_search_smart_location.recommendation_mode', FALSE);
  $fallback_broader_search = (bool) $request->attributes->get('spotdeals_search_smart_location.fallback_broader_search', FALSE);

  if ($recommendation_mode) {
    \Drupal::service('page_cache_kill_switch')->trigger();
    $view->element['#cache']['max-age'] = 0;
    $variables['#cache']['max-age'] = 0;
    $variables['#cache']['contexts'] = [];
    $variables['#cache']['tags'] = [];
  }

  if (!$recommendation_mode && !$fallback_broader_search) {
    return;
  }

  if ($fallback_broader_search && !$recommendation_mode) {
    _spotdeals_search_smart_location_add_fallback_message();
    return;
  }

  $direct_recommendation_deal_nid = _spotdeals_search_smart_location_get_direct_recommendation_deal_nid();
  $variables['spotdeals_direct_recommendation'] = [];

  if ($direct_recommendation_deal_nid > 0) {
    $variables['spotdeals_direct_recommendation'] = _spotdeals_search_smart_location_build_direct_recommendation_render($direct_recommendation_deal_nid);
  }

  $has_recommendation = !empty($variables['spotdeals_direct_recommendation']);

  if ($has_recommendation) {
    $recommendation_nearby_message = _spotdeals_search_smart_location_build_recommendation_nearby_message($direct_recommendation_deal_nid);
    if (!empty($recommendation_nearby_message)) {
      $variables['spotdeals_direct_recommendation'] = ['recommendation_nearby_message' => $recommendation_nearby_message] + $variables['spotdeals_direct_recommendation'];
    }
  }

  $variables['attributes']['data-recommendation-active'] = $has_recommendation ? '1' : '0';

  _spotdeals_search_smart_location_sync_filtered_pager($view, $has_recommendation ? 1 : 0);

  // The pager summary text is still built from internal pager state in a way
  // that does not reliably reflect our recommendation flow.
  // Recommendation mode intentionally shows exactly one selected deal card.
  $view->element['#attached']['html_head'][] = [
    [
      '#tag' => 'style',
      '#value' => '.view-id-deals_search_solr.view-display-id-page_1 .pager__summary{display:none !important;}',
    ],
    'spotdeals_search_smart_location_hide_recommendation_pager_summary',
  ];

  if ($has_recommendation) {
    \Drupal::logger('spotdeals_search_smart_location')->notice(
      'SMART LOCATION recommendation mode prepared direct recommendation render at preprocess_views_view: deal_nid="@nid"',
      [
        '@nid' => (string) $direct_recommendation_deal_nid,
      ]
    );
  }
  else {
    \Drupal::logger('spotdeals_search_smart_location')->notice(
      'SMART LOCATION recommendation mode had no direct recommendation render available at preprocess_views_view.'
    );
  }

  \Drupal::logger('spotdeals_search_smart_location')->notice(
    'SMART LOCATION recommendation mode adjusted pager summary at preprocess_views_view: forced_count="@count" summary_hidden="1"',
    [
      '@count' => $has_recommendation ? '1' : '0',
    ]
  );
}

/**
 * Implements hook_preprocess_views_view_unformatted().
 */
function spotdeals_search_smart_location_preprocess_views_view_unformatted(array &$variables): void {
  if (empty($variables['view']) || !$variables['view'] instanceof ViewExecutable) {
    return;
  }

  $view = $variables['view'];
  if ($view->id() !== 'deals_search_solr' || $view->current_display !== 'page_1') {
    return;
  }

  $request = \Drupal::request();
  $recommendation_mode = (bool) $request->attributes->get('spotdeals_search_smart_location.recommendation_mode', FALSE);
  $fallback_broader_search = (bool) $request->attributes->get('spotdeals_search_smart_location.fallback_broader_search', FALSE);

  if (!$recommendation_mode && !$fallback_broader_search) {
    return;
  }

  if ($fallback_broader_search && !$recommendation_mode) {
    _spotdeals_search_smart_location_add_fallback_message();
    return;
  }

  $direct_recommendation_deal_nid = _spotdeals_search_smart_location_get_direct_recommendation_deal_nid();
  if ($direct_recommendation_deal_nid <= 0) {
    return;
  }

  $before_count = is_array($variables['rows'] ?? NULL) ? count($variables['rows']) : 0;
  $variables['rows'] = [];

  \Drupal::logger('spotdeals_search_smart_location')->notice(
    'SMART LOCATION recommendation mode bypassed rendered view rows because direct recommendation rendering is active: before="@before" deal_nid="@nid"',
    [
      '@before' => (string) $before_count,
      '@nid' => (string) $direct_recommendation_deal_nid,
    ]
  );
}

/**
 * Returns the selected direct recommendation deal nid for the current request.
 */
function _spotdeals_search_smart_location_get_direct_recommendation_deal_nid(): int {
  $request = \Drupal::request();
  $direct_deal_nid = (int) $request->attributes->get('spotdeals_search_smart_location.direct_recommendation_deal_nid', 0);
  if ($direct_deal_nid > 0) {
    return $direct_deal_nid;
  }

  $current = $request->getSession()->get('spotdeals_search_smart_location.current_recommendation', []);
  if (is_array($current) && !empty($current['deal_nid'])) {
    return (int) $current['deal_nid'];
  }

  return 0;
}

/**
 * Builds the render array for the selected direct recommendation deal.
 *
 * @return array<string,mixed>
 *   A render array for the recommended deal card.
 */
function _spotdeals_search_smart_location_build_direct_recommendation_render(int $deal_nid): array {
  if ($deal_nid <= 0) {
    return [];
  }

  $deal = \Drupal::entityTypeManager()->getStorage('node')->load($deal_nid);
  if (!$deal instanceof NodeInterface) {
    return [];
  }

  $venue = _spotdeals_search_smart_location_deal_venue($deal);
  $venue_label = $venue instanceof NodeInterface ? $venue->label() : '';
  $venue_location = $venue instanceof NodeInterface
    ? _spotdeals_search_smart_location_format_direct_recommendation_location($venue)
    : '';
  $deal_label = $deal->label();
  $summary = _spotdeals_search_smart_location_extract_direct_recommendation_text($deal, [
    'body',
    'field_description',
    'field_deal_description',
    'field_offer_description',
    'field_details',
    'field_special_description',
  ]);
  $meta_values = _spotdeals_search_smart_location_collect_direct_recommendation_meta($deal, 3);

  $build = [
    '#type' => 'container',
    '#attributes' => [
      'class' => [
        'views-row',
        'spotdeals-direct-recommendation',
      ],
    ],
    '#cache' => [
      'max-age' => 0,
    ],
  ];

  if ($venue instanceof NodeInterface) {
    $build['venue_title'] = [
      '#type' => 'container',
      '#attributes' => [
        'class' => ['views-field', 'views-field-title'],
      ],
      'content' => [
        '#type' => 'html_tag',
        '#tag' => 'h2',
        '#attributes' => [
          'class' => ['venue-title'],
        ],
        'link' => [
          '#type' => 'link',
          '#title' => $venue_label,
          '#url' => $venue->toUrl(),
        ],
      ],
    ];
  }

  if ($venue_location !== '') {
    $build['venue_location'] = [
      '#type' => 'container',
      '#attributes' => [
        'class' => ['views-field', 'views-field-field-address-locality'],
      ],
      'content' => [
        '#type' => 'container',
        '#attributes' => [
          'class' => ['field-content'],
        ],
        '#plain_text' => $venue_location,
      ],
    ];
  }

  $build['deal_title'] = [
    '#type' => 'container',
    '#attributes' => [
      'class' => ['views-field', 'views-field-title-1'],
    ],
    'content' => [
      '#type' => 'html_tag',
      '#tag' => 'h3',
      '#attributes' => [
        'class' => ['deal-title'],
      ],
      'link' => [
        '#type' => 'link',
        '#title' => $deal_label,
        '#url' => $deal->toUrl(),
      ],
    ],
  ];

  if ($summary !== '') {
    $build['summary'] = [
      '#type' => 'container',
      '#attributes' => [
        'class' => ['views-field', 'views-field-body'],
      ],
      'content' => [
        '#type' => 'container',
        '#attributes' => [
          'class' => ['field-content'],
        ],
        '#plain_text' => $summary,
      ],
    ];
  }

  if (!empty($meta_values)) {
    foreach ($meta_values as $delta => $value) {
      $build['meta_' . $delta] = [
        '#type' => 'container',
        '#attributes' => [
          'class' => ['views-field', 'views-field-nothing'],
        ],
        'content' => [
          '#type' => 'container',
          '#attributes' => [
            'class' => ['field-content'],
          ],
          '#plain_text' => $value,
        ],
      ];
    }
  }

  if ($venue instanceof NodeInterface) {
    $build['venue_link'] = [
      '#type' => 'container',
      '#attributes' => [
        'class' => ['views-field', 'views-field-view-node'],
      ],
      'content' => [
        '#type' => 'container',
        '#attributes' => [
          'class' => ['field-content'],
        ],
        'link' => [
          '#type' => 'link',
          '#title' => t('View venue'),
          '#url' => $venue->toUrl(),
        ],
      ],
    ];
  }

  \Drupal::logger('spotdeals_search_smart_location')->notice(
    'SMART LOCATION recommendation mode built uncached direct recommendation view-like render: deal_nid="@nid" venue_nid="@venue_nid" venue_label="@venue"',
    [
      '@nid' => (string) $deal_nid,
      '@venue_nid' => $venue instanceof NodeInterface ? (string) $venue->id() : '',
      '@venue' => $venue_label,
    ]
  );

  return $build;
}

/**
 * Extracts the best text snippet for a direct recommendation card.
 *
 * @param array<int,string> $preferred_fields
 *   Preferred field machine names in priority order.
 */
function _spotdeals_search_smart_location_extract_direct_recommendation_text(NodeInterface $deal, array $preferred_fields): string {
  foreach ($preferred_fields as $field_name) {
    $value = _spotdeals_search_smart_location_get_direct_recommendation_field_text($deal, $field_name);
    $value = _spotdeals_search_smart_location_filter_direct_recommendation_text($value);
    if ($value !== '') {
      return $value;
    }
  }

  foreach ($deal->getFieldDefinitions() as $field_name => $definition) {
    if ($definition->isComputed()) {
      continue;
    }
    if (in_array($field_name, ['nid', 'vid', 'type', 'uuid', 'langcode', 'revision_timestamp', 'revision_uid', 'revision_log', 'uid', 'title', 'status', 'created', 'changed', 'promote', 'sticky', 'default_langcode', 'revision_translation_affected', 'path', 'menu_link', 'field_venue'], TRUE)) {
      continue;
    }

    $value = _spotdeals_search_smart_location_get_direct_recommendation_field_text($deal, $field_name);
    $value = _spotdeals_search_smart_location_filter_direct_recommendation_text($value);
    if ($value !== '') {
      return $value;
    }
  }

  return '';
}

/**
 * Collects compact deal metadata text lines for the direct recommendation card.
 *
 * @return array<int,string>
 *   Metadata lines.
 */
function _spotdeals_search_smart_location_collect_direct_recommendation_meta(NodeInterface $deal, int $limit = 3): array {
  $preferred_fields = [
    'field_price',
    'field_price_details',
    'field_time',
    'field_time_range',
    'field_start_time',
    'field_end_time',
    'field_days',
    'field_day',
    'field_day_of_week',
    'field_notes',
  ];

  $values = [];
  foreach ($preferred_fields as $field_name) {
    $value = _spotdeals_search_smart_location_get_direct_recommendation_field_text($deal, $field_name);
    $value = _spotdeals_search_smart_location_filter_direct_recommendation_text($value);
    if ($value === '' || in_array($value, $values, TRUE)) {
      continue;
    }

    $values[] = $value;
    if (count($values) >= $limit) {
      break;
    }
  }

  return $values;
}

/**
 * Returns a cleaned text value for a direct recommendation field.
 */
function _spotdeals_search_smart_location_get_direct_recommendation_field_text(NodeInterface $deal, string $field_name): string {
  if (!$deal->hasField($field_name) || $deal->get($field_name)->isEmpty()) {
    return '';
  }

  $value = trim((string) $deal->get($field_name)->value);
  if ($value === '') {
    $value = trim($deal->get($field_name)->getString());
  }

  $value = html_entity_decode(strip_tags($value), ENT_QUOTES | ENT_HTML5, 'UTF-8');
  $value = preg_replace('/\s+/u', ' ', $value) ?? '';
  return trim($value);
}

/**
 * Filters noisy text values from the direct recommendation card.
 */
function _spotdeals_search_smart_location_filter_direct_recommendation_text(string $value): string {
  $value = trim($value);
  if ($value === '') {
    return '';
  }

  if (preg_match('/^\d+$/', $value)) {
    return '';
  }

  $normalized = strtolower($value);
  $blocked = [
    '1',
    '47',
    '60',
    'claim this listing',
    'view venue',
  ];
  if (in_array($normalized, $blocked, TRUE)) {
    return '';
  }

  return $value;
}

/**
 * Formats the venue location line to match the normal search cards.
 */
function _spotdeals_search_smart_location_format_direct_recommendation_location(NodeInterface $venue): string {
  $city = _spotdeals_search_smart_location_node_locality($venue);
  $state = '';
  if ($venue->hasField('field_address') && !$venue->get('field_address')->isEmpty()) {
    $address = $venue->get('field_address')->first();
    if ($address && isset($address->administrative_area)) {
      $state = trim((string) $address->administrative_area);
    }
  }

  $parts = array_values(array_filter([$city, $state]));
  return implode(', ', $parts);
}

/**
 * Adds the broader-search fallback status message exactly once.
 */
function _spotdeals_search_smart_location_add_fallback_message(): void {
  $request = \Drupal::request();
  if ((bool) $request->attributes->get('spotdeals_search_smart_location.fallback_message_added', FALSE)) {
    return;
  }

  $request->attributes->set('spotdeals_search_smart_location.fallback_message_added', TRUE);

  \Drupal::messenger()->addStatus(t('No nearby matches found for “@query”. Showing broader Florida matches instead.', [
    '@query' => (string) $request->attributes->get('spotdeals_search_smart_location.raw_query', ''),
  ]));
}

/**
 * Builds the nearby recommendation fallback message exactly once.
 *
 * @return array<string,mixed>
 *   Inline recommendation message render array, or an empty array.
 */
function _spotdeals_search_smart_location_build_recommendation_nearby_message(int $deal_nid): array {
  if ($deal_nid <= 0) {
    return [];
  }

  $request = \Drupal::request();
  if ((bool) $request->attributes->get('spotdeals_search_smart_location.recommendation_nearby_message_added', FALSE)) {
    return [];
  }

  $raw_query = trim((string) $request->attributes->get('spotdeals_search_smart_location.raw_query', ''));
  if ($raw_query === '') {
    return [];
  }

  if (_spotdeals_search_smart_location_direct_recommendation_matches_query($deal_nid, $raw_query)) {
    return [];
  }

  $parsed = _spotdeals_search_smart_location_parse($raw_query);
  $keyword = trim((string) ($parsed['keywords'] ?? ''));
  if ($keyword === '') {
    $keyword = _spotdeals_search_smart_location_normalize_keywords($raw_query);
  }

  if ($keyword === '') {
    return [];
  }

  $request->attributes->set('spotdeals_search_smart_location.recommendation_nearby_message_added', TRUE);

  // Inline recommendation message rendered via Twig template.
  // Keep presentation out of PHP.
  return [
    '#theme' => 'spotdeals_search_smart_location_recommendation_note',
    '#keyword' => $keyword,
    '#attached' => [
      'library' => [
        'spotdeals_search_smart_location/recommendation_note',
      ],
    ],
    '#cache' => [
      'max-age' => 0,
    ],
  ];
}

/**
 * Returns TRUE when the selected direct recommendation matches the query.
 */
function _spotdeals_search_smart_location_direct_recommendation_matches_query(int $deal_nid, string $raw_query): bool {
  $deal = \Drupal::entityTypeManager()->getStorage('node')->load($deal_nid);
  if (!$deal instanceof NodeInterface) {
    return FALSE;
  }

  $tokens = preg_split('/\s+/', _spotdeals_search_smart_location_expand_keywords($raw_query)) ?: [];
  $tokens = array_values(array_unique(array_filter(array_map('trim', $tokens))));
  if (empty($tokens)) {
    return TRUE;
  }

  $haystacks = [];
  $haystacks[] = _spotdeals_search_smart_location_expand_keywords((string) $deal->label());

  if ($deal->hasField('body') && !$deal->get('body')->isEmpty()) {
    $haystacks[] = _spotdeals_search_smart_location_expand_keywords((string) $deal->get('body')->value);
  }

  $venue = NULL;
  if ($deal->hasField('field_venue') && !$deal->get('field_venue')->isEmpty()) {
    $venue_entity = $deal->get('field_venue')->entity;
    if ($venue_entity instanceof NodeInterface) {
      $venue = $venue_entity;
    }
  }

  if ($venue instanceof NodeInterface) {
    $haystacks[] = _spotdeals_search_smart_location_expand_keywords((string) $venue->label());

    if ($venue->hasField('field_short_description') && !$venue->get('field_short_description')->isEmpty()) {
      $haystacks[] = _spotdeals_search_smart_location_expand_keywords((string) $venue->get('field_short_description')->value);
    }

    $haystacks[] = _spotdeals_search_smart_location_expand_keywords(_spotdeals_search_smart_location_collect_node_term_labels($venue, 'field_cuisine'));
    $haystacks[] = _spotdeals_search_smart_location_expand_keywords(_spotdeals_search_smart_location_collect_node_term_labels($venue, 'field_tags'));
  }

  $haystack = implode(' ', array_filter($haystacks));
  if ($haystack === '') {
    return FALSE;
  }

  foreach ($tokens as $token) {
    if ($token !== '' && str_contains($haystack, $token)) {
      return TRUE;
    }
  }

  return FALSE;
}

/**
 * Collects referenced term labels from a node field.
 */
function _spotdeals_search_smart_location_collect_node_term_labels(NodeInterface $node, string $field_name): string {
  if (!$node->hasField($field_name) || $node->get($field_name)->isEmpty()) {
    return '';
  }

  $labels = [];
  foreach ($node->get($field_name)->referencedEntities() as $entity) {
    $labels[] = (string) $entity->label();
  }

  return implode(' ', $labels);
}

/**
 * Applies deterministic location ordering to View results.
 */
function _spotdeals_search_smart_location_apply_ranked_order(ViewExecutable $view): void {
  $request = \Drupal::request();
  $is_browser_near_me = (bool) $request->attributes->get('spotdeals_search_smart_location.browser_near_me', FALSE);
  $origin = $request->attributes->get('spotdeals_search_smart_location.origin');
  $ranked_nids = $request->attributes->get('spotdeals_search_smart_location.ranked_deal_nids');
  $exact_city = (string) $request->attributes->get('spotdeals_search_smart_location.city', '');

  if (empty($view->result)) {
    return;
  }

  $recommendation_mode = (bool) $request->attributes->get('spotdeals_search_smart_location.recommendation_mode', FALSE);
  if ($recommendation_mode) {
    return;
  }

  if ($is_browser_near_me) {
    _spotdeals_search_smart_location_apply_near_me_order($view, $origin, $ranked_nids, $exact_city);
    return;
  }

  if ($exact_city !== '') {
    _spotdeals_search_smart_location_apply_city_distance_sort($view, $origin, $exact_city);
  }
}

/**
 * Applies strict near-me ordering.
 *
 * @param array<string,mixed>|null $origin
 * @param array<int,int>|mixed $ranked_nids
 */
function _spotdeals_search_smart_location_apply_near_me_order(ViewExecutable $view, $origin, $ranked_nids, string $nearest_city): void {
  if (
    !is_array($origin) ||
    !isset($origin['lat'], $origin['lon']) ||
    !is_numeric($origin['lat']) ||
    !is_numeric($origin['lon'])
  ) {
    \Drupal::logger('spotdeals_search_smart_location')->notice(
      'SMART LOCATION pre_render near-me distance sort skipped: missing origin.'
    );
    return;
  }

  $origin_lat = (float) $origin['lat'];
  $origin_lon = (float) $origin['lon'];
  $radius_km = 25.0;
  $before_count = count($view->result);
  $order_map = is_array($ranked_nids) ? array_flip(array_values($ranked_nids)) : [];
  $filtered = [];
  $missing_coords = 0;
  $outside_radius = 0;
  $not_ranked = 0;

  foreach ($view->result as $index => $row) {
    $deal = _spotdeals_search_smart_location_result_entity($row);
    if (!$deal instanceof NodeInterface) {
      continue;
    }

    $venue = _spotdeals_search_smart_location_deal_venue($deal);
    if (!$venue instanceof NodeInterface) {
      $missing_coords++;
      continue;
    }

    $coords = _spotdeals_search_smart_location_node_coords($venue);
    if ($coords === NULL) {
      $missing_coords++;
      continue;
    }

    [$lat, $lon] = $coords;
    $distance_km = _spotdeals_search_smart_location_haversine_km($origin_lat, $origin_lon, $lat, $lon);
    if ($distance_km > $radius_km) {
      $outside_radius++;
      continue;
    }

    $nid = (int) $deal->id();
    if (!empty($order_map) && !isset($order_map[$nid])) {
      $not_ranked++;
    }

    $locality = _spotdeals_search_smart_location_node_locality($venue);

    $row->_spotdeals_distance_km = $distance_km;
    $row->_spotdeals_rank_index = $order_map[$nid] ?? PHP_INT_MAX;
    $row->_spotdeals_original_index = $index;
    $row->_spotdeals_nearest_city_match = $nearest_city !== ''
      && _spotdeals_search_smart_location_normalize_city($locality) === _spotdeals_search_smart_location_normalize_city($nearest_city);
    $filtered[] = $row;
  }

  if (empty($filtered)) {
    $view->result = [];
    _spotdeals_search_smart_location_reorder_rendered_fields($view, []);
    _spotdeals_search_smart_location_sync_filtered_pager($view);

    \Drupal::logger('spotdeals_search_smart_location')->notice(
      'SMART LOCATION pre_render near-me distance sort removed all rows: before="@before" missing_coords="@missing" outside_radius="@outside" not_ranked="@not_ranked" radius_km="@radius"',
      [
        '@before' => (string) $before_count,
        '@missing' => (string) $missing_coords,
        '@outside' => (string) $outside_radius,
        '@not_ranked' => (string) $not_ranked,
        '@radius' => (string) $radius_km,
      ]
    );
    return;
  }

  usort($filtered, static function ($a, $b): int {
    $a_distance = $a->_spotdeals_distance_km ?? PHP_FLOAT_MAX;
    $b_distance = $b->_spotdeals_distance_km ?? PHP_FLOAT_MAX;
    if ($a_distance !== $b_distance) {
      return $a_distance <=> $b_distance;
    }

    $a_rank = $a->_spotdeals_rank_index ?? PHP_INT_MAX;
    $b_rank = $b->_spotdeals_rank_index ?? PHP_INT_MAX;
    if ($a_rank !== $b_rank) {
      return $a_rank <=> $b_rank;
    }

    $a_original = $a->_spotdeals_original_index ?? PHP_INT_MAX;
    $b_original = $b->_spotdeals_original_index ?? PHP_INT_MAX;
    return $a_original <=> $b_original;
  });

  $view->result = array_values($filtered);
  _spotdeals_search_smart_location_reorder_rendered_fields($view, $view->result);
  _spotdeals_search_smart_location_sync_filtered_pager($view);

  $debug_rows = [];
  foreach (array_slice($view->result, 0, 10) as $position => $row) {
    $deal = _spotdeals_search_smart_location_result_entity($row);
    if (!$deal instanceof NodeInterface) {
      continue;
    }

    $venue = _spotdeals_search_smart_location_deal_venue($deal);
    $debug_rows[] = [
      'position' => $position + 1,
      'deal' => $deal->label(),
      'venue' => $venue instanceof NodeInterface ? $venue->label() : '',
      'city' => $venue instanceof NodeInterface ? _spotdeals_search_smart_location_node_locality($venue) : '',
      'distance_km' => isset($row->_spotdeals_distance_km) ? round((float) $row->_spotdeals_distance_km, 3) : NULL,
      'nearest_city_match' => !empty($row->_spotdeals_nearest_city_match) ? 1 : 0,
    ];
  }

  \Drupal::logger('spotdeals_search_smart_location')->notice(
    'SMART LOCATION pre_render applied hard near-me radius filter and strict distance sort: before="@before" after="@after" missing_coords="@missing" outside_radius="@outside" not_ranked="@not_ranked" radius_km="@radius" ranked_count="@ranked" nearest_city="@nearest_city" rows="@rows"',
    [
      '@before' => (string) $before_count,
      '@after' => (string) count($view->result),
      '@missing' => (string) $missing_coords,
      '@outside' => (string) $outside_radius,
      '@not_ranked' => (string) $not_ranked,
      '@radius' => (string) $radius_km,
      '@ranked' => is_array($ranked_nids) ? (string) count($ranked_nids) : '0',
      '@nearest_city' => $nearest_city,
      '@rows' => json_encode($debug_rows, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE),
    ]
  );
}

/**
 * Applies exact-city distance ordering without post-filtering rows.
 *
 * @param array<string,mixed>|null $origin
 */
function _spotdeals_search_smart_location_apply_city_distance_sort(ViewExecutable $view, $origin, string $exact_city): void {
  if (
    !is_array($origin) ||
    !isset($origin['lat'], $origin['lon']) ||
    !is_numeric($origin['lat']) ||
    !is_numeric($origin['lon'])
  ) {
    return;
  }

  $origin_lat = (float) $origin['lat'];
  $origin_lon = (float) $origin['lon'];
  $before_count = count($view->result);

  foreach ($view->result as $index => $row) {
    $deal = _spotdeals_search_smart_location_result_entity($row);
    if (!$deal instanceof NodeInterface) {
      continue;
    }

    $venue = _spotdeals_search_smart_location_deal_venue($deal);
    if (!$venue instanceof NodeInterface) {
      continue;
    }

    $coords = _spotdeals_search_smart_location_node_coords($venue);
    $distance = PHP_FLOAT_MAX;
    if ($coords !== NULL) {
      [$lat, $lon] = $coords;
      $distance = _spotdeals_search_smart_location_haversine_km($origin_lat, $origin_lon, $lat, $lon);
    }

    $row->_spotdeals_distance_km = $distance;
    $row->_spotdeals_original_index = $index;
  }

  usort($view->result, static function ($a, $b): int {
    $a_distance = $a->_spotdeals_distance_km ?? PHP_FLOAT_MAX;
    $b_distance = $b->_spotdeals_distance_km ?? PHP_FLOAT_MAX;
    if ($a_distance !== $b_distance) {
      return $a_distance <=> $b_distance;
    }

    $a_original = $a->_spotdeals_original_index ?? PHP_INT_MAX;
    $b_original = $b->_spotdeals_original_index ?? PHP_INT_MAX;
    return $a_original <=> $b_original;
  });

  $view->result = array_values($view->result);
  _spotdeals_search_smart_location_reorder_rendered_fields($view, $view->result);

  $debug_rows = [];
  foreach (array_slice($view->result, 0, 10) as $position => $row) {
    $deal = _spotdeals_search_smart_location_result_entity($row);
    if (!$deal instanceof NodeInterface) {
      continue;
    }

    $venue = _spotdeals_search_smart_location_deal_venue($deal);
    $debug_rows[] = [
      'position' => $position + 1,
      'deal' => $deal->label(),
      'venue' => $venue instanceof NodeInterface ? $venue->label() : '',
      'city' => $venue instanceof NodeInterface ? _spotdeals_search_smart_location_node_locality($venue) : '',
      'distance_km' => isset($row->_spotdeals_distance_km) && is_finite((float) $row->_spotdeals_distance_km)
        ? round((float) $row->_spotdeals_distance_km, 3)
        : NULL,
    ];
  }

  \Drupal::logger('spotdeals_search_smart_location')->notice(
    'SMART LOCATION pre_render applied exact city distance sort: before="@before" after="@after" city="@city" rows="@rows"',
    [
      '@before' => (string) $before_count,
      '@after' => (string) count($view->result),
      '@city' => $exact_city,
      '@rows' => json_encode($debug_rows, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE),
    ]
  );
}

/**
 * Forces a specific Views filter handler value.
 */
function _spotdeals_search_smart_location_force_filter_value(ViewExecutable $view, string $filter_id, string $value): void {
  if ($value === '') {
    return;
  }

  if (!$view->display_handler) {
    return;
  }

  $handler = $view->display_handler->getHandler('filter', $filter_id);
  if (!$handler) {
    return;
  }

  if (property_exists($handler, 'value')) {
    $handler->value = [
      'value' => $value,
      'min' => '',
      'max' => '',
    ];
  }

  if (property_exists($handler, 'operator')) {
    $handler->operator = '=';
  }

  if (method_exists($handler, 'acceptExposedInput')) {
    $handler->acceptExposedInput([$filter_id => $value]);
  }
}

/**
 * Reorders rendered fields to match reordered view results.
 *
 * @param array<int,mixed> $rows
 */
function _spotdeals_search_smart_location_reorder_rendered_fields(ViewExecutable $view, array $rows): void {
  if (!isset($view->style_plugin->rendered_fields) || !is_array($view->style_plugin->rendered_fields)) {
    return;
  }

  if (empty($rows)) {
    $view->style_plugin->rendered_fields = [];
    return;
  }

  $existing_rendered_fields = $view->style_plugin->rendered_fields;
  $reordered_rendered_fields = [];
  $matched_count = 0;

  foreach ($rows as $new_index => $row) {
    $old_index = $row->_spotdeals_original_index ?? NULL;

    if ($old_index !== NULL && array_key_exists($old_index, $existing_rendered_fields)) {
      $reordered_rendered_fields[$new_index] = $existing_rendered_fields[$old_index];
      $matched_count++;
      continue;
    }

    if (array_key_exists($new_index, $existing_rendered_fields)) {
      $reordered_rendered_fields[$new_index] = $existing_rendered_fields[$new_index];
      $matched_count++;
    }
  }

  if ($matched_count === count($rows) && !empty($reordered_rendered_fields)) {
    $view->style_plugin->rendered_fields = array_values($reordered_rendered_fields);
    return;
  }

  \Drupal::logger('spotdeals_search_smart_location')->notice(
    'SMART LOCATION skipped rendered_fields rewrite due to incomplete mapping: expected="@expected" matched="@matched"',
    [
      '@expected' => (string) count($rows),
      '@matched' => (string) $matched_count,
    ]
  );
}

/**
 * Sync pager/count metadata after post-filtering rows.
 */
function _spotdeals_search_smart_location_sync_filtered_pager(ViewExecutable $view, ?int $forced_count = NULL): void {
  $count = $forced_count ?? count($view->result);

  $view->total_rows = $count;

  if (isset($view->pager)) {
    if (property_exists($view->pager, 'total_items')) {
      $view->pager->total_items = $count;
    }

    if (property_exists($view->pager, 'current_page')) {
      $view->pager->current_page = 0;
    }

    if (property_exists($view->pager, 'total_pages')) {
      $items_per_page = 0;
      if (method_exists($view->pager, 'getItemsPerPage')) {
        $items_per_page = (int) $view->pager->getItemsPerPage();
      }
      elseif (property_exists($view->pager, 'options') && is_array($view->pager->options)) {
        $items_per_page = (int) ($view->pager->options['items_per_page'] ?? 0);
      }

      $view->pager->total_pages = ($items_per_page > 0 && $count > 0)
        ? (int) ceil($count / $items_per_page)
        : 1;
    }

    if (method_exists($view->pager, 'updatePageInfo')) {
      $view->pager->updatePageInfo();
    }
  }
}

/**
 * Submit handler for the deals finder exposed form.
 */
function spotdeals_search_smart_location_exposed_form_submit(array &$form, FormStateInterface $form_state): void {
  $trigger = $form_state->getTriggeringElement();
  $trigger_value = '';

  if (is_array($trigger) && isset($trigger['#value']) && is_string($trigger['#value'])) {
    $trigger_value = strtolower($trigger['#value']);
  }

  $op_value = $form_state->getValue('op');
  if ($trigger_value === '' && is_string($op_value)) {
    $trigger_value = strtolower($op_value);
  }

  if (strpos($trigger_value, 'reset') === FALSE) {
    return;
  }

  _spotdeals_search_smart_location_reset_recommendation_session();

  $path = \Drupal::request()->getPathInfo();
  $form_state->setRedirectUrl(Url::fromUserInput($path));
}

/**
 * Recommendation-mode validation for the deals finder exposed form.
 */
function spotdeals_search_smart_location_recommendation_validate(array &$form, FormStateInterface $form_state): void {
  $trigger = $form_state->getTriggeringElement();
  if (is_array($trigger) && isset($trigger['#value']) && is_string($trigger['#value']) && stripos($trigger['#value'], 'reset') !== FALSE) {
    return;
  }

  $values = $form_state->getValues();
  if (!_spotdeals_search_smart_location_is_recommendation_mode($values)) {
    return;
  }

  $cuisines = _spotdeals_search_smart_location_parse_recommendation_cuisines(
    (string) ($values['recommendation_cuisines'] ?? '')
  );


  if (count($cuisines) > 5) {
    $form_state->setErrorByName('recommendation_cuisines', t('Please enter no more than 5 cuisine preferences for Help me choose.'));
  }
}

/**
 * Returns TRUE when recommendation mode is enabled.
 *
 * @param array<string,mixed> $values
 */
function _spotdeals_search_smart_location_is_recommendation_mode(array $values): bool {
  $value = $values['help_me_choose'] ?? FALSE;

  if (is_string($value)) {
    return in_array(strtolower($value), ['1', 'true', 'on', 'yes'], TRUE);
  }

  return !empty($value);
}


/**
 * Returns venue IDs excluded in the current recommendation session.
 *
 * @return array<int,int>
 *   Excluded venue node IDs.
 */
function _spotdeals_search_smart_location_get_recommendation_exclusions(): array {
  $session = \Drupal::request()->getSession();
  $excluded_venue_nids = $session->get('spotdeals_search_smart_location.excluded_venue_nids', []);

  return array_values(array_unique(array_filter(
    array_map('intval', is_array($excluded_venue_nids) ? $excluded_venue_nids : []),
    static fn(int $nid): bool => $nid > 0
  )));
}

/**
 * Returns TRUE when a current recommendation exists in session.
 */
function _spotdeals_search_smart_location_has_current_recommendation(): bool {
  $current = \Drupal::request()->getSession()->get('spotdeals_search_smart_location.current_recommendation', []);
  return is_array($current) && !empty($current['deal_nid']) && !empty($current['venue_nid']);
}

/**
 * Clears recommendation-session state.
 */
function _spotdeals_search_smart_location_reset_recommendation_session(): void {
  $session = \Drupal::request()->getSession();
  $session->remove('spotdeals_search_smart_location.excluded_venue_nids');
  $session->remove('spotdeals_search_smart_location.current_recommendation');
}

/**
 * Stores the current recommendation for the next try-again action.
 *
 * @param array<int,int> $recommended_nids
 *   Recommended deal NIDs.
 */
function _spotdeals_search_smart_location_store_current_recommendation(array $recommended_nids): void {
  $session = \Drupal::request()->getSession();

  $recommended_nids = array_values(array_unique(array_filter(
    array_map('intval', $recommended_nids),
    static fn(int $nid): bool => $nid > 0
  )));

  if (empty($recommended_nids)) {
    $session->remove('spotdeals_search_smart_location.current_recommendation');
    return;
  }

  $deal = \Drupal::entityTypeManager()->getStorage('node')->load($recommended_nids[0]);
  if (!$deal instanceof NodeInterface) {
    $session->remove('spotdeals_search_smart_location.current_recommendation');
    return;
  }

  $venue = _spotdeals_search_smart_location_deal_venue($deal);
  $venue_nid = $venue instanceof NodeInterface ? (int) $venue->id() : 0;

  if ($venue_nid <= 0) {
    $session->remove('spotdeals_search_smart_location.current_recommendation');
    return;
  }

  $session->set('spotdeals_search_smart_location.current_recommendation', [
    'deal_nid' => (int) $deal->id(),
    'venue_nid' => $venue_nid,
  ]);

  \Drupal::logger('spotdeals_search_smart_location')->notice(
    'SMART LOCATION stored current recommendation in session: deal_nid="@deal" venue_nid="@venue"',
    [
      '@deal' => (string) $deal->id(),
      '@venue' => (string) $venue_nid,
    ]
  );
}

/**
 * Applies the current recommendation to session exclusions.
 */
function _spotdeals_search_smart_location_apply_recommendation_action_to_session(string $action): void {
  if ($action !== 'retry') {
    return;
  }

  $session = \Drupal::request()->getSession();
  $current = $session->get('spotdeals_search_smart_location.current_recommendation', []);

  if (!is_array($current) || empty($current['venue_nid'])) {
    $session->remove('spotdeals_search_smart_location.excluded_venue_nids');
    return;
  }

  // Keep only the immediately previous venue excluded for the next
  // recommendation attempt. This matches the product rule that the last
  // recommended result must not repeat in the same session, while avoiding
  // exhausting the pool after just a few retries.
  $venue_nid = (int) $current['venue_nid'];
  if ($venue_nid <= 0) {
    $session->remove('spotdeals_search_smart_location.excluded_venue_nids');
    return;
  }

  $session->set('spotdeals_search_smart_location.excluded_venue_nids', [$venue_nid]);

  \Drupal::logger('spotdeals_search_smart_location')->notice(
    'SMART LOCATION applied retry exclusion in session: excluded_venue_nids="@excluded" from_current="@current"',
    [
      '@excluded' => json_encode([$venue_nid], JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE),
      '@current' => json_encode($current, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE),
    ]
  );
}

/**
 * Parses recommendation cuisines into normalized tokens.
 *
 * @return array<int,string>
 */
function _spotdeals_search_smart_location_parse_recommendation_cuisines(string $value): array {
  $value = strtolower(trim($value));
  if ($value === '') {
    return [];
  }

  $value = preg_replace('/[,|\/]+/', ' ', $value) ?? $value;
  $value = _spotdeals_search_smart_location_normalize_keywords($value);
  $parts = preg_split('/\s+/', $value) ?: [];
  $parts = array_values(array_unique(array_filter(array_map('trim', $parts))));

  return $parts;
}

/**
 * Parse one-box input into keywords + zip + city.
 *
 * @return array{keywords:string,zip:?string,city:?string}
 */
function _spotdeals_search_smart_location_parse(string $input): array {
  $normalized = strtolower(trim($input));
  $normalized = preg_replace('/\s+/', ' ', $normalized ?? '') ?? '';
  $normalized = preg_replace('/[,\.;]+/', ' ', $normalized) ?? '';
  $normalized = trim($normalized);

  $zip = NULL;
  if (preg_match('/\b(\d{5})(?:-\d{4})?\b/', $normalized, $matches)) {
    $zip = $matches[1];
    $normalized = trim(str_replace($matches[0], ' ', $normalized));
  }

  $city = NULL;
  $matched_city_phrase = NULL;
  $cities = _spotdeals_search_smart_location_known_cities();
  uksort($cities, static fn(string $a, string $b): int => strlen($b) <=> strlen($a));

  foreach ($cities as $slug => $label) {
    $phrase = strtolower($slug);
    if (preg_match('/(^|\s)' . preg_quote($phrase, '/') . '(\s|$)/', $normalized)) {
      $city = $slug;
      $matched_city_phrase = $phrase;
      $normalized = trim((string) preg_replace('/(^|\s)' . preg_quote($phrase, '/') . '(\s|$)/', ' ', $normalized));
      break;
    }
  }

  $keywords = trim($normalized);

  if ($matched_city_phrase !== NULL) {
    $keywords = trim(str_replace($matched_city_phrase, '', $keywords));
  }

  $keywords = _spotdeals_search_smart_location_normalize_keywords($keywords);

  return [
    'keywords' => $keywords,
    'zip' => $zip,
    'city' => $city,
  ];
}

/**
 * Return exact locality from known city slug.
 */
function _spotdeals_search_smart_location_city_to_exact_locality(string $city_slug): ?string {
  $cities = _spotdeals_search_smart_location_known_cities();
  return $cities[$city_slug] ?? NULL;
}

/**
 * Known city names.
 *
 * @return array<string, string>
 *   Map of normalized slug => exact locality label.
 */
function _spotdeals_search_smart_location_known_cities(): array {
  static $cities = NULL;

  if (is_array($cities)) {
    return $cities;
  }

  $cache = \Drupal::cache('data');
  $cache_id = 'spotdeals_search_smart_location:known_cities';
  $cached = $cache->get($cache_id);
  if ($cached && is_array($cached->data)) {
    $cities = $cached->data;
    return $cities;
  }

  $connection = Database::getConnection();
  $query = $connection->select('node__field_address', 'addr');
  $query->join('node_field_data', 'venue', 'venue.nid = addr.entity_id');
  $query->fields('addr', ['field_address_locality']);
  $query->distinct();
  $query->condition('addr.field_address_locality', '', '<>');
  $query->isNotNull('addr.field_address_locality');
  $query->condition('venue.type', 'venue');
  $query->condition('venue.status', 1);

  $results = $query->execute()->fetchCol();

  $cities = [];
  foreach ($results as $city_label) {
    $exact_label = trim((string) $city_label);
    if ($exact_label === '') {
      continue;
    }

    foreach (_spotdeals_search_smart_location_city_aliases($exact_label) as $alias) {
      if (!isset($cities[$alias])) {
        $cities[$alias] = $exact_label;
      }
    }
  }

  $cache->set($cache_id, $cities, CacheBackendInterface::CACHE_PERMANENT);

  return $cities;
}

/**
 * Build normalized aliases for an exact city label.
 *
 * @return array<int, string>
 *   Normalized aliases ordered from most specific to least specific.
 */
function _spotdeals_search_smart_location_city_aliases(string $exact_label): array {
  $aliases = [];

  $normalized_compact = _spotdeals_search_smart_location_normalize_city_alias($exact_label);
  if ($normalized_compact !== '') {
    $aliases[] = $normalized_compact;
  }

  $spaced_label = preg_replace('/(?<=\p{Ll})(?=\p{Lu})/u', ' ', $exact_label) ?? $exact_label;
  $normalized_spaced = _spotdeals_search_smart_location_normalize_city_alias($spaced_label);
  if ($normalized_spaced !== '' && !in_array($normalized_spaced, $aliases, TRUE)) {
    $aliases[] = $normalized_spaced;
  }

  $words = $normalized_spaced !== '' ? explode(' ', $normalized_spaced) : [];
  if (count($words) >= 3) {
    $prefix_alias = implode(' ', array_slice($words, 0, -1));
    if ($prefix_alias !== '' && !in_array($prefix_alias, $aliases, TRUE)) {
      $aliases[] = $prefix_alias;
    }

    $initialism = implode('', array_map(static fn(string $word): string => substr($word, 0, 1), $words));
    if ($initialism !== '' && !in_array($initialism, $aliases, TRUE)) {
      $aliases[] = $initialism;
    }
  }

  return $aliases;
}

/**
 * Normalize a city alias for matching.
 */
function _spotdeals_search_smart_location_normalize_city_alias(string $value): string {
  $value = strtolower(trim($value));
  $value = preg_replace('/[^a-z0-9\s]+/', ' ', $value) ?? '';
  $value = preg_replace('/\s+/', ' ', $value) ?? '';
  return trim($value);
}

/**
 * Resolve an origin coordinate from parsed zip/city.
 *
 * @param array<string, mixed> $parsed
 *
 * @return array{lat: float, lon: float}|null
 */
function _spotdeals_search_smart_location_resolve_origin_from_venues(array $parsed): ?array {
  $zip = isset($parsed['zip']) && is_string($parsed['zip']) ? $parsed['zip'] : '';
  $city = isset($parsed['city']) && is_string($parsed['city']) ? $parsed['city'] : '';

  if ($zip === '' && $city === '') {
    return NULL;
  }

  $storage = \Drupal::entityTypeManager()->getStorage('node');
  $query = \Drupal::entityQuery('node')
    ->accessCheck(FALSE)
    ->condition('type', 'venue')
    ->condition('status', 1)
    ->range(0, 250);

  if ($zip !== '') {
    $query->condition('field_address.postal_code', $zip);
  }

  if ($city !== '') {
    $exact_city = _spotdeals_search_smart_location_city_to_exact_locality($city);
    if ($exact_city !== NULL) {
      $query->condition('field_address.locality', $exact_city);
    }
  }

  $nids = $query->execute();
  if (empty($nids)) {
    return NULL;
  }

  $venues = $storage->loadMultiple($nids);
  $coords = [];

  foreach ($venues as $venue) {
    if (!$venue instanceof NodeInterface) {
      continue;
    }

    $point = _spotdeals_search_smart_location_node_coords($venue);
    if ($point !== NULL) {
      $coords[] = $point;
    }
  }

  if (empty($coords)) {
    return NULL;
  }

  $lat_sum = 0.0;
  $lon_sum = 0.0;
  foreach ($coords as [$lat, $lon]) {
    $lat_sum += $lat;
    $lon_sum += $lon;
  }

  return [
    'lat' => $lat_sum / count($coords),
    'lon' => $lon_sum / count($coords),
  ];
}

/**
 * Normalize semantic keywords before they are sent to Solr.
 */
function _spotdeals_search_smart_location_normalize_keywords(string $keywords): string {
  $normalized = strtolower(trim($keywords));
  if ($normalized === '') {
    return '';
  }

  $normalized = preg_replace('/[\.,;:!\?\(\)\[\]\"\']+/u', ' ', $normalized) ?? '';
  $normalized = preg_replace('/\bnear\s+me\b/u', ' ', $normalized) ?? '';
  $normalized = preg_replace('/\b(show\s+me|find|search\s+for)\b/u', ' ', $normalized) ?? '';
  $normalized = preg_replace('/\b(best|top|good)\b/u', ' ', $normalized) ?? '';
  $normalized = preg_replace('/\bbarbecue\b/u', 'bbq', $normalized) ?? '';
  $normalized = preg_replace('/\s+/', ' ', $normalized) ?? '';

  return trim($normalized);
}

/**
 * Resolve nearest known city from browser coordinates.
 */
function _spotdeals_search_smart_location_nearest_city_from_coords(float $origin_lat, float $origin_lon): ?string {
  $storage = \Drupal::entityTypeManager()->getStorage('node');
  $nids = \Drupal::entityQuery('node')
    ->accessCheck(FALSE)
    ->condition('type', 'venue')
    ->condition('status', 1)
    ->range(0, 250)
    ->execute();

  if (empty($nids)) {
    return NULL;
  }

  $venues = $storage->loadMultiple($nids);
  $closest_city = NULL;
  $closest_distance = NULL;

  foreach ($venues as $venue) {
    if (!$venue instanceof NodeInterface) {
      continue;
    }

    $locality = _spotdeals_search_smart_location_node_locality($venue);
    if ($locality === '') {
      continue;
    }

    $coords = _spotdeals_search_smart_location_node_coords($venue);
    if ($coords === NULL) {
      continue;
    }

    [$lat, $lon] = $coords;
    $distance = _spotdeals_search_smart_location_haversine_km($origin_lat, $origin_lon, $lat, $lon);

    if ($closest_distance === NULL || $distance < $closest_distance) {
      $closest_distance = $distance;
      $closest_city = $locality;
    }
  }

  return $closest_city;
}

/**
 * Normalize near-me keywords without hardcoded synonym expansion.
 */
function _spotdeals_search_smart_location_expand_keywords(string $keywords): string {
  $normalized = _spotdeals_search_smart_location_normalize_keywords($keywords);
  if ($normalized === '') {
    return '';
  }

  $normalized = preg_replace('/[^\p{L}\p{N}\s]+/u', ' ', $normalized) ?? '';
  $normalized = preg_replace('/\s+/', ' ', $normalized) ?? '';
  $tokens = preg_split('/\s+/', trim($normalized)) ?: [];
  $tokens = array_values(array_unique(array_filter(array_map('trim', $tokens))));

  return implode(' ', $tokens);
}

/**
 * Returns the entity for a Views result row if present.
 */
function _spotdeals_search_smart_location_result_entity(object $row): ?NodeInterface {
  if (isset($row->_entity) && $row->_entity instanceof NodeInterface) {
    return $row->_entity;
  }

  if (isset($row->entity) && $row->entity instanceof NodeInterface) {
    return $row->entity;
  }

  return NULL;
}

/**
 * Returns the related venue for a deal.
 */
function _spotdeals_search_smart_location_deal_venue(NodeInterface $deal): ?NodeInterface {
  if (!$deal->hasField('field_venue') || $deal->get('field_venue')->isEmpty()) {
    return NULL;
  }

  $venue = $deal->get('field_venue')->entity;
  return $venue instanceof NodeInterface ? $venue : NULL;
}

/**
 * Returns a normalized locality label for a venue node.
 */
function _spotdeals_search_smart_location_node_locality(NodeInterface $node): string {
  if (!$node->hasField('field_address') || $node->get('field_address')->isEmpty()) {
    return '';
  }

  $address = $node->get('field_address')->first();
  if (!is_object($address) || !isset($address->locality)) {
    return '';
  }

  return trim((string) $address->locality);
}

/**
 * Returns postal code for a venue node.
 */
function _spotdeals_search_smart_location_node_postal_code(NodeInterface $node): string {
  if (!$node->hasField('field_address') || $node->get('field_address')->isEmpty()) {
    return '';
  }

  $address = $node->get('field_address')->first();
  if (!is_object($address) || !isset($address->postal_code)) {
    return '';
  }

  return trim((string) $address->postal_code);
}

/**
 * Returns coordinates from a node or NULL.
 *
 * @return array{0: float, 1: float}|null
 */
function _spotdeals_search_smart_location_node_coords(NodeInterface $node): ?array {
  if (!$node->hasField('field_coordinates') || $node->get('field_coordinates')->isEmpty()) {
    return NULL;
  }

  $value = (string) $node->get('field_coordinates')->value;
  if ($value === '') {
    return NULL;
  }

  if (preg_match('/POINT\s*\(\s*(-?[0-9.]+)\s+(-?[0-9.]+)\s*\)/i', $value, $matches)) {
    $lon = (float) $matches[1];
    $lat = (float) $matches[2];
    return [$lat, $lon];
  }

  if (str_contains($value, ',')) {
    [$lat, $lon] = array_map('trim', explode(',', $value, 2));
    if (is_numeric($lat) && is_numeric($lon)) {
      return [(float) $lat, (float) $lon];
    }
  }

  if (
    $node->hasField('field_latitude') &&
    !$node->get('field_latitude')->isEmpty() &&
    $node->hasField('field_longitude') &&
    !$node->get('field_longitude')->isEmpty()
  ) {
    $lat = $node->get('field_latitude')->value;
    $lon = $node->get('field_longitude')->value;
    if (is_numeric($lat) && is_numeric($lon)) {
      return [(float) $lat, (float) $lon];
    }
  }

  return NULL;
}

/**
 * Normalize city labels for comparison.
 */
function _spotdeals_search_smart_location_normalize_city(string $city): string {
  $city = strtolower(trim($city));
  $city = preg_replace('/\s+/', ' ', $city ?? '') ?? '';
  return $city;
}

/**
 * Returns city centroid distance from the user's origin.
 */
function _spotdeals_search_smart_location_city_centroid_distance_km(string $city, float $origin_lat, float $origin_lon): float {
  static $cache = [];

  $key = _spotdeals_search_smart_location_normalize_city($city) . '|' . $origin_lat . '|' . $origin_lon;
  if (isset($cache[$key])) {
    return $cache[$key];
  }

  $exact_city = trim($city);
  if ($exact_city === '') {
    $cache[$key] = PHP_FLOAT_MAX;
    return $cache[$key];
  }

  $storage = \Drupal::entityTypeManager()->getStorage('node');
  $nids = \Drupal::entityQuery('node')
    ->accessCheck(FALSE)
    ->condition('type', 'venue')
    ->condition('status', 1)
    ->condition('field_address.locality', $exact_city)
    ->range(0, 250)
    ->execute();

  if (empty($nids)) {
    $cache[$key] = PHP_FLOAT_MAX;
    return $cache[$key];
  }

  $venues = $storage->loadMultiple($nids);
  $coords = [];
  foreach ($venues as $venue) {
    if (!$venue instanceof NodeInterface) {
      continue;
    }

    $point = _spotdeals_search_smart_location_node_coords($venue);
    if ($point !== NULL) {
      $coords[] = $point;
    }
  }

  if (empty($coords)) {
    $cache[$key] = PHP_FLOAT_MAX;
    return $cache[$key];
  }

  $lat_sum = 0.0;
  $lon_sum = 0.0;
  foreach ($coords as [$lat, $lon]) {
    $lat_sum += $lat;
    $lon_sum += $lon;
  }

  $centroid_lat = $lat_sum / count($coords);
  $centroid_lon = $lon_sum / count($coords);

  $cache[$key] = _spotdeals_search_smart_location_haversine_km($origin_lat, $origin_lon, $centroid_lat, $centroid_lon);
  return $cache[$key];
}

/**
 * Haversine formula in kilometers.
 */
function _spotdeals_search_smart_location_haversine_km(float $lat1, float $lon1, float $lat2, float $lon2): float {
  $earth_radius_km = 6371.0;

  $lat1_rad = deg2rad($lat1);
  $lon1_rad = deg2rad($lon1);
  $lat2_rad = deg2rad($lat2);
  $lon2_rad = deg2rad($lon2);

  $lat_delta = $lat2_rad - $lat1_rad;
  $lon_delta = $lon2_rad - $lon1_rad;

  $angle = 2 * asin(sqrt(
    pow(sin($lat_delta / 2), 2) +
    cos($lat1_rad) * cos($lat2_rad) * pow(sin($lon_delta / 2), 2)
  ));

  return $earth_radius_km * $angle;
}

/**
 * Stores a pending normalized search term for later result-aware logging.
 */
function _spotdeals_search_smart_location_prepare_search_insight(string $raw, string $normalized, bool $recommendation_mode): void {
  $request = \Drupal::request();

  $request->attributes->remove('spotdeals_search_smart_location.pending_search_insight');

  if ($recommendation_mode) {
    return;
  }

  $raw = trim($raw);
  $normalized = trim($normalized);

  if ($raw === '' || $normalized === '') {
    return;
  }

  if (!\Drupal::hasService('spotdeals_search_insights.logger')) {
    return;
  }

  $request->attributes->set('spotdeals_search_smart_location.pending_search_insight', [
    'raw' => $raw,
    'normalized' => $normalized,
  ]);
}

/**
 * Logs one normalized search term only when the rendered search has results.
 */
function _spotdeals_search_smart_location_commit_search_insight(ViewExecutable $view): void {
  if (!\Drupal::hasService('spotdeals_search_insights.logger')) {
    return;
  }

  $request = \Drupal::request();
  $pending = $request->attributes->get('spotdeals_search_smart_location.pending_search_insight');

  if (!is_array($pending)) {
    return;
  }

  $request->attributes->remove('spotdeals_search_smart_location.pending_search_insight');

  $result_count = is_array($view->result ?? NULL) ? count($view->result) : 0;
  if ($result_count < 1) {
    return;
  }

  $raw = isset($pending['raw']) && is_string($pending['raw']) ? trim($pending['raw']) : '';
  $normalized = isset($pending['normalized']) && is_string($pending['normalized']) ? trim($pending['normalized']) : '';

  if ($raw === '' || $normalized === '') {
    return;
  }

  try {
    \Drupal::service('spotdeals_search_insights.logger')->log($raw, $normalized);
  }
  catch (\Throwable $e) {
    \Drupal::logger('spotdeals_search_smart_location')->warning(
      'SMART LOCATION search insight logging skipped due to logger error: @message',
      ['@message' => $e->getMessage()]
    );
  }
}

<div class="spotdeals-recommendation-note" role="status" aria-live="polite">
  <span class="spotdeals-recommendation-note__icon" aria-hidden="true"></span>
  <div class="spotdeals-recommendation-note__content">
    <span class="spotdeals-recommendation-note__line">
      {% trans %}No <strong>{{ keyword }}</strong> spots found nearby (within 25 miles).{% endtrans %}
    </span>
    <span class="spotdeals-recommendation-note__line">
      {{ 'Here’s a nearby pick for you.'|t }}
    </span>
  </div>
</div>

{#
/**
 * @file
 * Share links for venue and deal detail pages.
 */
#}
{% set encoded_url = url|url_encode %}
{% set encoded_title = title|url_encode %}

<section class="spotdeals-share-this" aria-label="{{ 'Share this'|t }}">
  <details class="spotdeals-share-this__details">
    <summary class="spotdeals-share-this__summary">{{ 'Share this'|t }}</summary>
    <div class="spotdeals-share-this__links">
      <a href="{{ url }}" class="spotdeals-share-this__link">{{ 'Open link'|t }}</a>
      <a href="https://www.facebook.com/sharer/sharer.php?u={{ encoded_url }}" class="spotdeals-share-this__link" target="_blank" rel="noopener noreferrer">{{ 'Facebook'|t }}</a>
      <a href="https://twitter.com/intent/tweet?text={{ encoded_title }}&url={{ encoded_url }}" class="spotdeals-share-this__link" target="_blank" rel="noopener noreferrer">{{ 'X'|t }}</a>
      <a href="https://wa.me/?text={{ encoded_title }}%20{{ encoded_url }}" class="spotdeals-share-this__link" target="_blank" rel="noopener noreferrer">{{ 'WhatsApp'|t }}</a>
      <a href="mailto:?subject={{ encoded_title }}&body={{ encoded_url }}" class="spotdeals-share-this__link">{{ 'Email'|t }}</a>
    </div>
  </details>
</section>

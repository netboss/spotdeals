      'address' => [
        'description' => 'Suggested venue address.',
        'type' => 'varchar',
        'length' => 512,
        'not null' => TRUE,
        'default' => '',
      ],
      'street_address' => [
        'description' => 'Suggested venue street address.',
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'default' => '',
      ],
      'city' => [
        'description' => 'Suggested venue city.',
        'type' => 'varchar',
        'length' => 128,
        'not null' => TRUE,
        'default' => '',
      ],
      'state' => [
        'description' => 'Suggested venue state or province.',
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
        'default' => '',
      ],
      'zip' => [
        'description' => 'Suggested venue ZIP or postal code.',
        'type' => 'varchar',
        'length' => 32,
        'not null' => TRUE,
        'default' => '',
      ],
      'country' => [
        'description' => 'Suggested venue country.',
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
        'default' => 'US',
      ],
      'deal_location' => [
        'description' => 'City or ZIP used to match deal suggestions to the correct venue location.',
        'type' => 'varchar',
        'length' => 128,
        'not null' => TRUE,
        'default' => '',
      ],
      'website' => [
        'description' => 'Suggested venue or deal website URL.',
        'type' => 'varchar',
        'length' => 512,
        'not null' => TRUE,
        'default' => '',
      ],
      'deal_name' => [
        'description' => 'Suggested deal name.',
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'default' => '',
      ],
      'deal_description' => [
        'description' => 'Suggested deal details.',
        'type' => 'text',
        'size' => 'big',
        'not null' => FALSE,
      ],
      'days' => [
        'description' => 'Suggested active days.',
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'default' => '',
      ],
      'times' => [
        'description' => 'Suggested active times.',
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'default' => '',
      ],
      'notes' => [
        'description' => 'Additional notes from the submitter.',
        'type' => 'text',
        'size' => 'big',
        'not null' => FALSE,
      ],
      'email' => [
        'description' => 'Optional submitter email address.',
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'default' => '',
      ],
      'status' => [
        'description' => 'Suggestion moderation status.',
        'type' => 'varchar',
        'length' => 32,
        'not null' => TRUE,
        'default' => 'new',
      ],
      'created_entity_type' => [
        'description' => 'Entity type created from this suggestion, if any.',
        'type' => 'varchar',
        'length' => 32,
        'not null' => TRUE,
        'default' => '',
      ],
      'created_entity_bundle' => [
        'description' => 'Entity bundle created from this suggestion, if any.',
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
        'default' => '',
      ],
      'created_entity_id' => [

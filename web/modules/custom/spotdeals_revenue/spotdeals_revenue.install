      'id' => [
        'description' => 'Primary suggestion ID.',
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'type' => [
        'description' => 'Suggestion type: venue, deal, or both.',
        'type' => 'varchar',
        'length' => 16,
        'not null' => TRUE,
        'default' => 'deal',
      ],
      'venue_name' => [
        'description' => 'Suggested venue name.',
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'default' => '',

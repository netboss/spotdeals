/**
 * Registers the public suggestion form with the existing CAPTCHA module.
 */
function spotdeals_revenue_update_9005(): void {
  if (!\Drupal::moduleHandler()->moduleExists('captcha')) {
    return;
  }

  $form_id = 'spotdeals_suggestion_form';

  try {
    $entity_type_manager = \Drupal::entityTypeManager();
    if ($entity_type_manager->hasDefinition('captcha_point')) {
      $storage = $entity_type_manager->getStorage('captcha_point');
      $captcha_point = $storage->load($form_id);

      if (!$captcha_point) {
        $captcha_point = $storage->create([
          'id' => $form_id,
          'formId' => $form_id,
          'captchaType' => 'default',
          'label' => $form_id,
          'status' => TRUE,
        ]);
      }
      else {
        $captcha_point->set('formId', $form_id);
        $captcha_point->set('captchaType', 'default');
        $captcha_point->set('status', TRUE);
      }

      $captcha_point->save();
      return;
    }
  }
  catch (\Throwable $e) {
    \Drupal::logger('spotdeals_revenue')->warning('Could not create CAPTCHA point for @form_id using entity storage: @message', [
      '@form_id' => $form_id,
      '@message' => $e->getMessage(),
    ]);
  }

  // Fallback for CAPTCHA versions that store points directly as config.
  \Drupal::configFactory()->getEditable('captcha.captcha_point.' . $form_id)
    ->set('formId', $form_id)
    ->set('captchaType', 'default')
    ->set('label', $form_id)
    ->set('status', TRUE)
    ->save();
}

/**
 * Adds city/ZIP context for deal suggestion matching.
 */
function spotdeals_revenue_update_9006(): void {
  $schema = \Drupal::database()->schema();

  if (!$schema->fieldExists('spotdeals_suggestion', 'deal_location')) {
    $schema->addField('spotdeals_suggestion', 'deal_location', [
      'description' => 'City or ZIP used to match deal suggestions to the correct venue location.',
      'type' => 'varchar',
      'length' => 128,
      'not null' => TRUE,
      'default' => '',
    ]);
  }
}



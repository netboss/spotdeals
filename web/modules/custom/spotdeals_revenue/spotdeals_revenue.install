        'length' => 64,
        'not null' => TRUE,
        'default' => '',
      ],
      'owner_notification_attempt_count' => [
        'description' => 'Number of owner notification attempts for this suggestion.',
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
      ],
      'owner_notification_last_attempt' => [
        'description' => 'Unix timestamp of the most recent owner notification attempt.',
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
      ],
      'owner_notification_failure_reason' => [
        'description' => 'Failure reason from the most recent owner notification attempt.',
        'type' => 'varchar',
        'length' => 512,
        'not null' => TRUE,
        'default' => '',
      ],
      'uid' => [
        'description' => 'Submitting user ID, or 0 for anonymous users.',
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
      ],
      'created' => [
        'description' => 'Unix timestamp when the suggestion was submitted.',
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
      ],
      'changed' => [
        'description' => 'Unix timestamp when the suggestion was last changed.',
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
      ],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'status_created' => ['status', 'created'],
      'type_created' => ['type', 'created'],
    ],
  ];

  return $schema;
}


/**
 * Converts old reviewed suggestion statuses to approved.
 */
function spotdeals_revenue_update_9001(): void {
  \Drupal::database()->update('spotdeals_suggestion')
    ->fields(['status' => 'approved'])
    ->condition('status', 'reviewed')
    ->execute();
}


/**
 * Adds created content tracking fields to suggestions.
 */
function spotdeals_revenue_update_9002(): void {
  $schema = \Drupal::database()->schema();

  $fields = [
    'created_entity_type' => [
      'description' => 'Entity type created from this suggestion, if any.',
      'type' => 'varchar',
      'length' => 32,
      'not null' => TRUE,
      'default' => '',
    ],
    'created_entity_bundle' => [
      'description' => 'Entity bundle created from this suggestion, if any.',
      'type' => 'varchar',
      'length' => 64,
      'not null' => TRUE,
      'default' => '',
    ],
    'created_entity_id' => [
      'description' => 'Entity ID created from this suggestion, if any.',
      'type' => 'int',
      'unsigned' => TRUE,
      'not null' => TRUE,
      'default' => 0,
    ],
  ];

  foreach ($fields as $field_name => $field_spec) {
    if (!$schema->fieldExists('spotdeals_suggestion', $field_name)) {
      $schema->addField('spotdeals_suggestion', $field_name, $field_spec);
    }
  }

  \Drupal::database()->update('spotdeals_suggestion')
    ->fields(['status' => 'added'])
    ->condition('status', 'imported')
    ->execute();
}

/**
 * Normalizes suggestion statuses for the direct-create workflow.
 */
function spotdeals_revenue_update_9003(): void {
  $connection = \Drupal::database();

  $connection->update('spotdeals_suggestion')
    ->fields(['status' => 'approved'])
    ->condition('status', 'ready_to_import')
    ->execute();

  $connection->update('spotdeals_suggestion')
    ->fields(['status' => 'published'])
    ->condition('status', 'imported')
    ->execute();

  $connection->update('spotdeals_suggestion')
    ->fields(['status' => 'published'])
    ->condition('status', 'added')
    ->condition('created_entity_id', 0, '>')
    ->execute();
}


{#
/**
 * @file
 * Theme override for the Deals Search (Solr) view.
 *
 * Available variables:
 * - attributes: HTML attributes for the container.
 * - css_name: A CSS-safe version of the view name.
 * - css_class: CSS classes.
 * - header: The view header.
 * - footer: The view footer.
 * - rows: The results.
 * - empty: The empty text.
 * - exposed: Exposed widget form / filters.
 * - pager: The pager output.
 * - more: "More" link.
 * - feed_icons: Feed icons.
 * - title: The view title.
 * - attachment_before: Attachments before.
 * - attachment_after: Attachments after.
 * - dom_id: Unique DOM id.
 * - spotdeals_result_count: Real number of rendered result rows.
 */
#}
{%
  set classes = [
    'view',
    'view-' ~ id,
    'view-id-' ~ id,
    'view-display-id-' ~ display_id,
    dom_id ? 'js-view-dom-id-' ~ dom_id,
    'spotdeals-finder'
  ]
%}
<div{{ attributes.addClass(classes) }}>
  <section class="spotdeals-finder__intro">
    {% if title and not is_front %}
      <h2 class="spotdeals-finder__title">{{ title }}</h2>
    {% endif %}
    <p class="spotdeals-finder__description">
      Search by food, time, or location to discover nearby deals.
    </p>
  </section>

  {% if exposed %}
    <section class="spotdeals-finder__filters">
      <div
        hx-get="/"
        hx-target=".spotdeals-finder__results"
        hx-select=".spotdeals-finder__results"
        hx-swap="outerHTML"
        hx-push-url="true"
      >
        {{ exposed }}
      </div>
    </section>
  {% endif %}

  <section class="spotdeals-finder__results">
    {% if header %}
      <div class="view-header">
        {{ header }}
      </div>
    {% endif %}

    {% if attachment_before %}
      <div class="attachment attachment-before">
        {{ attachment_before }}
      </div>
    {% endif %}

    {% if rows %}
      <div class="view-content" data-result-count="{{ spotdeals_result_count }}">
        {{ rows }}
      </div>
    {% elseif empty %}
      <div class="view-empty" data-result-count="{{ spotdeals_result_count }}">
        {{ empty }}
      </div>
    {% endif %}

    {% if pager %}
      {{ pager }}
    {% endif %}

    {% if attachment_after %}
      <div class="attachment attachment-after">
        {{ attachment_after }}
      </div>
    {% endif %}

    {% if more %}
      {{ more }}
    {% endif %}

    {% if footer %}
      <div class="view-footer">
        {{ footer }}
      </div>
    {% endif %}

    {% if feed_icons %}
      <div class="feed-icons">
        {{ feed_icons }}
      </div>
    {% endif %}
  </section>
</div>

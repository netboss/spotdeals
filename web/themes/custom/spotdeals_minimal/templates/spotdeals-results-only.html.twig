<div class="spotdeals-finder__results">
  {% if data.is_recommendation_mode %}
    {% set start = data.result_count > 0 ? 1 : 0 %}

    <div class="view-header">
      {% if language.getId() == 'es' %}
        Mostrando {{ start }} - {{ data.result_count }} de {{ data.result_count }}
      {% else %}
        Displaying {{ start }} - {{ data.result_count }} of {{ data.result_count }}
      {% endif %}
    </div>
  {% elseif data.header %}
    <div class="view-header">
      {{ data.header }}
    </div>
  {% endif %}

  {% if data.attachment_before %}
    <div class="attachment attachment-before">
      {{ data.attachment_before }}
    </div>
  {% endif %}

  {% if data.rows %}
    <div class="view-content" data-result-count="{{ data.result_count }}">
      {{ data.rows }}
    </div>
    {% if data.is_recommendation_mode %}
      <div class="spotdeals-finder__suggestion-cta spotdeals-finder__suggestion-cta--after-results">
        <div class="spotdeals-finder__suggestion-cta-copy">
          <strong>{{ "Not the venue or deal you had in mind?"|t }}</strong>
          <span>{{ "Suggest one and we will review it."|t }}</span>
        </div>
        <a class="spotdeals-finder__suggestion-cta-button" href="{{ path('spotdeals_revenue.suggest') }}">{{ "Suggest a venue or deal"|t }}</a>
      </div>
    {% endif %}
  {% elseif data.empty %}
    <div class="view-empty" data-result-count="{{ data.result_count }}">
      {{ data.empty }}
      <div class="spotdeals-finder__suggestion-cta spotdeals-finder__suggestion-cta--empty">
        <div class="spotdeals-finder__suggestion-cta-copy">
          <strong>{{ "Still not finding it?"|t }}</strong>
          <span>{{ "Tell us what venue or deal is missing."|t }}</span>
        </div>
        <a class="spotdeals-finder__suggestion-cta-button" href="{{ path('spotdeals_revenue.suggest') }}">{{ "Suggest a venue or deal"|t }}</a>
      </div>
    </div>
  {% endif %}

  {% if not data.is_recommendation_mode and data.pager %}
    {{ data.pager }}
  {% endif %}

  {% if data.attachment_after %}
    <div class="attachment attachment-after">
      {{ data.attachment_after }}
    </div>
  {% endif %}
</div>
